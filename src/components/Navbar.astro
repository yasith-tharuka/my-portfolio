---
// src/components/Navbar.astro
---

<header class="w-full border-b border-gray-200 bg-white sticky top-0 z-50">
    <div
        class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between relative"
    >
        <!-- Left: Logo/Name -->
        <div class="flex items-center">
            <a
                href="/"
                class="flex items-center gap-2 text-black hover:opacity-90 transition-opacity"
            >
                <span
                    class="font-heading font-medium text-lg text-gray-900 tracking-tight flex items-center"
                >
                    <span class="font-semibold text-gray-900 tracking-tight"
                        >Yasith</span
                    >
                    <span class="font-medium text-gray-600 ml-1 tracking-tight"
                        >Tharuka</span
                    >
                </span>
            </a>
        </div>

        <!-- Center: Navigation Links-->
        <nav
            class="hidden md:flex items-center gap-2 text-[15px] text-gray-650 font-medium"
        >
            <!-- Project Dropdown Button -->
            <button
                id="product-menu-btn"
                class="text-gray-600 px-4 py-1.5 rounded-full
         hover:bg-[#F1F3F4] hover:text-black
         transition-colors flex items-center gap-1.5
         focus:outline-none font-medium cursor-pointer"
            >
                Projects
                <svg
                    class="w-2.5 h-2.5 text-gray-700 transition-transform duration-250"
                    id="product-arrow"
                    viewBox="0 0 10 10"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M7 2 v5 h-5"></path>
                </svg>
            </button>

            <!-- Experience Dropdown Button -->
            <button
                id="experience-menu-btn"
                class="text-gray-600 px-4 py-1.5 rounded-full
         hover:bg-[#F1F3F4] hover:text-black
         transition-colors flex items-center gap-1.5
         focus:outline-none font-medium cursor-pointer"
            >
                Experience
                <svg
                    class="w-2.5 h-2.5 text-gray-700 transition-transform duration-250"
                    id="experience-arrow"
                    viewBox="0 0 10 10"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M7 2 v5 h-5"></path>
                </svg>
            </button>

            <a
                href="/certifications"
                class="hover:bg-[#F1F3F4] hover:text-black px-4 py-1.5 rounded-full transition-colors text-gray-600"
                >Certificates</a
            >
            <a
                href="#blog"
                class="hover:bg-[#F1F3F4] hover:text-black px-4 py-1.5 rounded-full transition-colors text-gray-600"
                >Blog</a
            >

            <!-- Resources Dropdown Button -->
            <button
                id="resources-menu-btn"
                class="text-gray-600 px-4 py-1.5 rounded-full
         hover:bg-[#F1F3F4] hover:text-black
         transition-colors flex items-center gap-1.5
         focus:outline-none font-medium cursor-pointer"
            >
                Resources
                <svg
                    class="w-2.5 h-2.5 text-gray-700 transition-transform duration-250"
                    id="resources-arrow"
                    viewBox="0 0 10 10"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M7 2 v5 h-5"></path>
                </svg>
            </button>
        </nav>

        <!-- Right: Download / Mobile Toggles -->
        <div class="flex items-center gap-3">
            <a
                href="#download"
                class="hidden md:flex bg-[#0F0F10] text-white px-5 py-2.5 rounded-full text-sm font-medium hover:bg-gray-800 transition-colors items-center gap-2"
            >
                Contact
            </a>

            <!-- Mobile Hamburger Toggle -->
            <button
                id="mobile-menu-toggle"
                class="md:hidden flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-100 transition-colors focus:outline-none cursor-pointer"
                aria-label="Toggle menu"
            >
                <svg
                    class="w-6 h-6 text-gray-900"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>

            <!-- Mobile Close Button (Mockup accurate: circular black with white X) -->
            <button
                id="mobile-menu-close"
                class="hidden items-center justify-center w-10 h-10 bg-[#0F0F10] text-white rounded-full hover:bg-gray-800 transition-colors focus:outline-none cursor-pointer"
                aria-label="Close menu"
            >
                <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>

        <!-- Mega Menu Dropdown Panel (Positions directly under the navbar, spanning full width) -->
        <div
            id="product-mega-menu"
            class="absolute top-full left-0 w-full bg-white border-b border-gray-200 shadow-sm hidden opacity-0 -translate-y-2 transition-all duration-200 z-40 rounded-b-3xl"
        >
            <div
                class="max-w-7xl mx-auto px-6 py-10 grid grid-cols-12 gap-8 relative"
            >
                <!-- Left Side: Large Descriptive Text -->
                <div class="col-span-12 md:col-span-4 pr-6">
                    <h3
                        class="font-heading text-2xl font-normal text-gray-400 leading-tight"
                    >
                        Pushing the boundaries of <br />computation and
                        intelligent systems.
                    </h3>
                </div>

                <!-- Vertical Divider (Visible on desktop) -->
                <div
                    class="hidden md:block absolute left-[35%] top-10 bottom-10 border-l border-gray-200"
                >
                </div>

                <!-- Right Side: List of sub-links -->
                <div class="col-span-12 md:col-span-8 md:pl-16">
                    <span
                        class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-5"
                    >
                        Projects
                    </span>

                    <ul class="space-y-4">
                        <li>
                            <a
                                href="#antigravity-2-0"
                                class="flex items-center gap-3.5 group text-base font-medium text-gray-900 hover:text-[#4285F4] transition-colors"
                            >
                                <div
                                    class="w-6 h-6 flex items-center justify-center"
                                >
                                    <svg
                                        class="w-5 h-5 text-gray-800 group-hover:text-[#4285F4] transition-colors"
                                        fill="currentColor"
                                        viewBox="0 0 128 128"
                                    >
                                        <path
                                            d="M50.4 78.5a75.1 75.1 0 0 0-28.5 6.9l24.2-65.7c.7-2 1.9-3.2 3.4-3.2h29c1.5 0 2.7 1.2 3.4 3.2l24.2 65.7s-11.6-7-28.5-7L67 45.5c-.4-1.7-1.6-2.8-2.9-2.8-1.3 0-2.5 1.1-2.9 2.7L50.4 78.5Zm-1.1 28.2Zm-4.2-20.2c-2 6.6-.6 15.8 4.2 20.2a17.5 17.5 0 0 1 .2-.7 5.5 5.5 0 0 1 5.7-4.5c2.8.1 4.3 1.5 4.7 4.7.2 1.1.2 2.3.2 3.5v.4c0 2.7.7 5.2 2.2 7.4a13 13 0 0 0 5.7 4.9v-.3l-.2-.3c-1.8-5.6-.5-9.5 4.4-12.8l1.5-1a73 73 0 0 0 3.2-2.2 16 16 0 0 0 6.8-11.4c.3-2 .1-4-.6-6l-.8.6-1.6 1a37 37 0 0 1-22.4 2.7c-5-.7-9.7-2-13.2-6.2Z"
                                        ></path>
                                    </svg>
                                </div>
                                Project 01
                            </a>
                        </li>
                        <li>
                            <a
                                href="#antigravity-cli"
