---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";

const title = "Academic Journey & Qualifications | Yasith Tharuka";
const description = "An interactive, verified chronicle of my academic degrees, GPA standings, extracurricular leadership roles, and official transcripts.";

const educationData = [
  {
    id: "sliit-hdip",
    degree: "Higher Diploma in Information Technology (Software Engineering)",
    shortDegree: "Higher Diploma in IT (SE)",
    institution: "SLIIT City UNI",
    awardingBody: "Awarded by SLIIT City Uni (Subsidiary of SLIIT)",
    period: "Jul 2025 – Jul 2027",
    grade: "Expected",
    gradeLabel: "Current Standing",
    gradeValue: "In Progress / Expected",
    gradeSub: "Expected Graduation: Jul 2027",
    gradeColor: "text-blue-600 bg-blue-50/70 border-blue-150",
    progressPercent: 35,
    progressLabel: "Degree Progress",
    activities: [
      {
        role: "IEEE SB Public Visibility Sub‑Committee Member",
        desc: "Leading visual communications, graphics design guidelines, and branding layouts across the student branch events."
      },
      {
        role: "ICPC 2026 Student Branch Ambassador",
        desc: "Coordinating team registrations, regional communication channels, and logistics for local participants."
      },
      {
        role: "SESC Member",
        desc: "Software Engineering Student Community active participant, collaborating on code sessions and peer workshops."
      }
    ],
    skills: [
      "Academic English",
      "Software Development",
      "Object-Oriented Programming (OOP)",
      "Data Structures & Algorithms",
      "Web Technologies",
      "Git & Collaborative Workflow"
    ],
    logoType: "sliit",
    logo: "/certificates/Issuer_Logos/sliit_logo.jpg",
    accentColor: "#4285F4", // Blue
    bgGrad: "from-blue-500/10 to-indigo-500/5",
    documents: []
  },
  {
    id: "sliit-fcit",
    degree: "Foundation Certificate in Information Technology (FCIT)",
    shortDegree: "Foundation Cert in IT",
    field: "Information Technology",
    institution: "SLIIT City UNI",
    awardingBody: "Awarded by SLIIT City Uni (Subsidiary of SLIIT)",
    period: "Jul 2024 – Jul 2025",
    grade: "GPA: 3.21",
    gradeLabel: "Academic Performance",
    gradeValue: "3.21 GPA",
    gradeSub: "Scale: 4.00",
    gradeColor: "text-emerald-600 bg-emerald-50/70 border-emerald-150",
    progressPercent: 100,
    progressLabel: "Completed",
    activities: [
      {
        role: "IEEE Student Member",
        desc: "Engaged in professional development, technical seminars, and student hackathon operations."
      },
      {
        role: "Photography Club Committee Member",
        desc: "Assisted in club meeting logistics, photo walk operations, and high-resolution event coverage."
      }
    ],
    skills: [
      "C# Programming",
      "Project Management",
      "Database Systems (SQL)",
      "UI/UX Design Fundamentals",
      "Computer Networking",
      "Problem Solving",
      "Academic Communication"
    ],
    logoType: "sliit",
    logo: "/certificates/Issuer_Logos/sliit_logo.jpg",
    accentColor: "#34A853", // Green
    bgGrad: "from-emerald-500/10 to-teal-500/5",
    documents: [
      {
        name: "FCIT Certificate File",
        filename: "FCIT_Certificate.jpg",
        type: "image",
        url: "/certificates/FCIT_Certificate.jpg",
        thumbnail: "/certificates/FCIT_Certificate.jpg",
        description: "Official Foundation Certificate in IT transcript and credentials."
      }
    ]
  },
  {
    id: "othm-spoken-english",
    degree: "International Diploma in Spoken English (Level 3)",
    shortDegree: "Diploma in Spoken English",
    field: "Spoken English",
    institution: "OTHM Qualifications",
    awardingBody: "Completed through ICBT Campus, Sri Lanka – an approved teaching center for OTHM Qualifications. European Qualification Framework (EQF) Level 4.",
    period: "Oct 2024 – Apr 2025",
    grade: "Pass",
    gradeLabel: "Evaluation Status",
    gradeValue: "Pass",
    gradeSub: "European Qualification Framework (EQF) Level 4",
    gradeColor: "text-purple-600 bg-purple-50/70 border-purple-150",
    progressPercent: 100,
    progressLabel: "Completed",
    activities: [
      {
        role: "Completed through ICBT Campus",
        desc: "Attended intensive sessions on public speaking guidelines and oral diagnostics at ICBT Colombo."
      },
      {
        role: "EQF Level 4 Framework Verification",
        desc: "Validated standardized credits aligned with international language competency scales."
      }
    ],
    skills: [
      "Presentation Skills",
      "Public Speaking",
      "Verbal Communication",
      "Professional English",
      "Interpersonal Skills"
    ],
    logoType: "othm",
    logo: "", // Render custom SVG/CSS OTHM logo
    accentColor: "#8B5CF6", // Purple
    bgGrad: "from-purple-500/10 to-pink-500/5",
    documents: [
      {
        name: "Official OTHM Certificate",
        filename: "spoken_english_certificate.pdf",
        type: "pdf",
        url: "/certificates/spoken_english_certificate.pdf",
        thumbnail: "/certificates/spoken_english_certificate.pdf",
        description: "Level 3 International Diploma Certificate issued by OTHM Qualifications."
      },
      {
        name: "Academic CQF Transcript",
        filename: "spoken_english_transcript.pdf",
        type: "pdf",
        url: "/certificates/spoken_english_transcript.pdf",
        thumbnail: "/certificates/spoken_english_transcript.pdf",
        description: "Official credit transcript documenting modular speaking scores."
      }
    ]
  },
  {
    id: "thelijjawila-secondary",
    degree: "Secondary School Education (GCE Ordinary Level)",
    shortDegree: "Ordinary Level (Secondary)",
    field: "Formal subjects",
    institution: "Thelijjawila Central College",
    awardingBody: "Thelijjawila Central College, Sri Lanka",
    period: "Feb 2019 – Nov 2023",
    grade: "3 A’s, 3 B’s, 3 C’s",
    gradeLabel: "GCE O/L Results (2021)",
    gradeValue: "3 A's, 3 B's, 3 C's",
    gradeSub: "Credential ID: CL‑CK1339",
    gradeColor: "text-amber-600 bg-amber-50/70 border-amber-150",
    progressPercent: 100,
    progressLabel: "Completed",
    activities: [
      {
        role: "Founder & Leader – School Stamp Society (2022–2024)",
        desc: "Initiated the formal stamp society, organized school exhibitions, and managed weekly newsletters."
      },
      {
        role: "Participant – SLIC “Sahasak Nimavum” (2020 & 2021)",
        desc: "Competed in the national invention competition, presenting prototype mechanics."
      },
      {
        role: "Prize Winner – “Brain Busters” Quiz (SLIIT)",
        desc: "Won regional team positions in the national school quiz competition organized by SLIIT."
      }
    ],
    skills: [
      "Critical Thinking",
      "Teamwork",
      "Leadership & Organization",
      "Creative Innovation"
    ],
    logoType: "school",
    logo: "", // Render custom SVG/CSS school logo
    accentColor: "#FBBC05", // Amber
    bgGrad: "from-amber-500/10 to-orange-500/5",
    documents: [
      {
        name: "Verification Link",
        filename: "certificate.doenets.lk",
        type: "link",
        url: "https://certificate.doenets.lk",
        thumbnail: "",
        description: "Official results verification portal via the Department of Examinations, Sri Lanka. Credential ID: CL-CK1339"
      }
    ]
  }
];
---

<Layout title={title}>
  <main class="w-full min-h-screen bg-[#FAFAFC] relative overflow-hidden pt-12 pb-24 font-body">
    <!-- Background Magic Bubbles for Premium Glow -->
    <div class="absolute top-10 left-5 w-60 h-60 rounded-full bg-blue-400/15 blur-3xl animate-float-bubble-1 pointer-events-none"></div>
    <div class="absolute bottom-10 right-5 w-72 h-72 rounded-full bg-emerald-400/12 blur-3xl animate-float-bubble-2 pointer-events-none"></div>
    <div class="absolute top-1/3 left-1/4 w-44 h-44 rounded-full bg-amber-400/8 blur-3xl animate-float-bubble-3 pointer-events-none"></div>
    <div class="absolute bottom-1/3 right-1/4 w-48 h-48 rounded-full bg-purple-400/8 blur-3xl pointer-events-none"></div>

    <!-- Header Section -->
    <section class="max-w-7xl mx-auto px-6 mb-12 relative z-20">
      <div class="flex flex-col md:flex-row md:items-start justify-between gap-8 pb-10 border-b border-gray-200/80">
        <!-- Left: Sleek title and subtext -->
        <div class="max-w-3xl">
          <span class="text-xs font-semibold text-[#4285F4] uppercase tracking-widest block mb-3 font-san">Education</span>
          <h1 class="font-san text-4xl sm:text-5xl font-normal text-gray-900 tracking-tight leading-tight mb-4">
            Academic Journey & Dossier
          </h1>
          <p class="text-base sm:text-lg text-gray-505 leading-relaxed font-light">
            An interactive chronicle of my official degrees, transcripts, marks sheets, and leadership activities across academic institutions.
          </p>
        </div>

        <!-- Right: Return to Home button matching certifications -->
        <div class="flex-shrink-0 mt-4 md:mt-2">
          <a
            href="/"
            class="inline-flex items-center gap-2 bg-white/20 hover:bg-white/35 text-gray-900 hover:text-black px-6 py-2.5 rounded-full text-xs sm:text-sm font-medium transition-all duration-200 hover:-translate-y-0.5 font-san border border-white/30 hover:border-white/50 shadow-sm backdrop-blur-md"
            id="back-home-button"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
               <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Return to Home
          </a>
        </div>
      </div>
    </section>

    <!-- Main Dashboard Workspace -->
    <section class="max-w-7xl mx-auto px-6 relative z-20">
      <div class="flex flex-col md:flex-row gap-8 items-start">
        
        <!-- Mobile Selector (Horizontal scrolling pill list) -->
        <div class="flex md:hidden w-full overflow-x-auto gap-3 pb-3 mb-2 snap-x scrollbar-hide" id="mobile-tabs-scroll">
          {educationData.map((edu, idx) => (
            <button
              class={`mobile-tab-btn px-4 py-2.5 rounded-full text-xs font-medium border whitespace-nowrap snap-center transition-all duration-200 cursor-pointer ${
                idx === 0
                  ? "bg-white text-gray-900 border-[#4285F4] shadow-sm font-semibold active-tab"
                  : "bg-white/40 text-gray-550 border-gray-200/60 hover:bg-white/60"
              }`}
              data-target={edu.id}
            >
              {edu.shortDegree}
            </button>
          ))}
        </div>

        <!-- Desktop Sidebar Timeline Selector (Left Panel) -->
        <div class="hidden md:flex flex-col gap-4 w-80 flex-shrink-0 relative border-l border-gray-200/80 pl-6 py-2">
          {educationData.map((edu, idx) => (
            <button
              class={`sidebar-tab-btn w-full text-left p-4 rounded-2xl border transition-all duration-300 relative group cursor-pointer ${
                idx === 0
                  ? "bg-white border-white shadow-md shadow-gray-100/50 scale-[1.02] text-gray-900 active-tab"
                  : "bg-white/40 border-transparent text-gray-500 hover:bg-white/65 hover:border-white/40 hover:text-gray-800"
              }`}
              data-target={edu.id}
              id={`tab-btn-${edu.id}`}
            >
              <!-- Selector active dot indicator -->
              <span class={`absolute left-[-29px] top-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full transition-all duration-300 ${
                idx === 0 
                  ? "bg-[#4285F4] scale-100 ring-4 ring-blue-100" 
                  : "bg-gray-300 scale-75 group-hover:scale-100 group-hover:bg-gray-400"
              }`} id={`dot-${edu.id}`}></span>

              <div class="flex items-center gap-3">
                <!-- Icon wrapper -->
                <span class="w-10 h-10 flex items-center justify-center bg-white border border-gray-100 rounded-xl flex-shrink-0 overflow-hidden shadow-sm group-hover:scale-105 transition-transform">
                  {edu.logoType === 'sliit' ? (
                    <img src={edu.logo} alt="SLIIT" class="w-full h-full object-contain p-1" />
                  ) : edu.logoType === 'othm' ? (
                    <span class="font-san font-bold text-[10px] text-purple-600 tracking-tighter">OTHM</span>
                  ) : (
                    <svg class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                    </svg>
                  )}
                </span>

                <div class="overflow-hidden">
                  <span class="block text-[10px] font-semibold tracking-wider text-gray-400 uppercase">{edu.period}</span>
                  <h3 class="font-san text-sm font-medium leading-snug truncate group-hover:text-black transition-colors">{edu.shortDegree}</h3>
                  <span class="block text-xs font-light text-gray-500 truncate">{edu.institution}</span>
                </div>
              </div>
            </button>
          ))}
        </div>

        <!-- Dashboard Dossier Details Panel (Right Panel) -->
        <div class="flex-1 w-full relative min-h-[500px]" id="dossier-details-container">
          {educationData.map((edu, idx) => (
            <div
              id={`sheet-${edu.id}`}
              class={`dossier-sheet w-full bg-white/40 backdrop-blur-xl border border-white/50 rounded-[2.2rem] p-6 sm:p-8 md:p-10 flex flex-col justify-between shadow-[inset_0_1px_2px_rgba(255,255,255,0.65),0_8px_32px_rgba(0,0,0,0.02)] transition-all duration-300 ${
                idx === 0 ? "block translate-y-0 opacity-100" : "hidden translate-y-4 opacity-0"
              }`}
            >
              
              <!-- Sheet Header -->
              <div class="flex flex-col sm:flex-row justify-between items-start gap-6 pb-6 border-b border-gray-200/50 mb-8 relative z-10">
                <div class="flex items-start gap-4">
                  <!-- Large School Logo -->
                  <div class="w-16 h-16 bg-white border border-gray-150 rounded-2xl flex items-center justify-center p-2 flex-shrink-0 shadow-sm">
                    {edu.logoType === 'sliit' ? (
                      <img src={edu.logo} alt="SLIIT" class="w-full h-full object-contain" />
                    ) : edu.logoType === 'othm' ? (
                      <div class="flex flex-col items-center justify-center leading-none">
                        <span class="font-san font-extrabold text-sm text-purple-600 tracking-tighter">OTHM</span>
                        <span class="text-[5px] font-semibold text-gray-400 tracking-widest mt-0.5">UK</span>
                      </div>
                    ) : (
                      <div class="flex flex-col items-center justify-center text-amber-500">
                        <svg class="w-9 h-9" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                        </svg>
                      </div>
                    )}
                  </div>
                  <div>
                    <h2 class="font-san text-xl sm:text-2xl font-normal text-gray-900 leading-snug">{edu.degree}</h2>
                    <p class="text-sm font-semibold text-[#4285F4] mt-1 font-san flex items-center gap-1.5">
                      <span>{edu.institution}</span>
                      <span class="inline-block w-1.5 h-1.5 rounded-full bg-gray-300"></span>
                      <span class="text-gray-500 font-normal">{edu.period}</span>
                    </p>
                  </div>
                </div>

                <!-- Academic Period Tag -->
                <span class="px-4 py-1.5 text-xs font-semibold uppercase tracking-wider rounded-full bg-white/70 border border-gray-200/60 shadow-sm text-gray-500">
                  {edu.period}
                </span>
              </div>

              <!-- Sheet Grid Workspace -->
              <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 relative z-10">
                
                <!-- Left Details Grid Column (Academic Stats, Award details & Skills) -->
                <div class="lg:col-span-5 flex flex-col gap-6">
                  
                  <!-- Grade / Performance Widget Card -->
                  <div class="bg-white/60 border border-white/60 p-6 rounded-3xl shadow-[0_4px_20px_rgba(0,0,0,0.01)] flex flex-col justify-between">
                    <div>
                      <span class="text-[10px] font-semibold text-gray-400 uppercase tracking-widest block mb-3">{edu.gradeLabel}</span>
                      <div class="flex items-baseline gap-2 mb-2">
                        <span class={`text-3xl font-san font-medium ${edu.id === 'sliit-hdip' ? 'text-blue-600' : edu.id === 'sliit-fcit' ? 'text-emerald-600' : edu.id === 'othm-spoken-english' ? 'text-purple-600' : 'text-amber-500'}`}>{edu.grade}</span>
                      </div>
                      <p class="text-xs text-gray-550 leading-relaxed font-light">{edu.gradeSub}</p>
                    </div>

                    <!-- Visual Progress Gauge indicator -->
                    <div class="mt-6 pt-5 border-t border-gray-100">
                      <div class="flex justify-between text-[11px] font-semibold text-gray-400 mb-1.5">
                        <span>{edu.progressLabel}</span>
                        <span>{edu.progressPercent}%</span>
                      </div>
                      <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden">
                        <div 
                          class="h-full rounded-full transition-all duration-1000 ease-out" 
                          style={`width: ${edu.progressPercent}%; background-color: ${edu.accentColor};`}
                        ></div>
                      </div>
                    </div>
                  </div>

                  <!-- Awarding Details & Credentials Body -->
                  <div class="bg-white/60 border border-white/60 p-6 rounded-3xl shadow-[0_4px_20px_rgba(0,0,0,0.01)]">
                    <span class="text-[10px] font-semibold text-gray-400 uppercase tracking-widest block mb-3">Academic Registry</span>
                    <h4 class="text-sm font-semibold text-gray-800 mb-1">Awarding Authority</h4>
                    <p class="text-xs text-gray-550 leading-relaxed font-light mb-4">{edu.awardingBody}</p>
                    
                    <div class="flex items-center gap-2 mt-4 pt-4 border-t border-gray-100">
                      <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></span>
                      <span class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Verified Registry Entry</span>
                    </div>
                  </div>

                  <!-- Skills Card -->
                  <div class="bg-white/60 border border-white/60 p-6 rounded-3xl shadow-[0_4px_20px_rgba(0,0,0,0.01)]">
                    <span class="text-[10px] font-semibold text-gray-400 uppercase tracking-widest block mb-4">Core Competencies</span>
                    <div class="flex flex-wrap gap-2">
                      {edu.skills.map((skill) => (
                        <span 
                          class="px-3 py-1.5 rounded-lg text-xs font-medium bg-white/95 border border-gray-150 text-gray-700 shadow-[0_1px_2px_rgba(0,0,0,0.02)] select-none hover:border-gray-300 transition-colors"
                          style={`--hover-accent: ${edu.accentColor}`}
                        >
                          {skill}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>

                <!-- Right Details Grid Column (Activities and Documents) -->
                <div class="lg:col-span-7 flex flex-col gap-6">
                  
                  <!-- Activities & Student Societies Card -->
                  <div class="bg-white/60 border border-white/60 p-6 sm:p-8 rounded-3xl shadow-[0_4px_20px_rgba(0,0,0,0.01)] flex-1">
                    <span class="text-[10px] font-semibold text-gray-400 uppercase tracking-widest block mb-5">Activities & Student Societies</span>
                    <ul class="space-y-6">
                      {edu.activities.map((act) => (
                        <li class="flex items-start gap-3.5 group">
                          <span 
                            class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 border border-gray-200 transition-colors"
                            style={`background-color: ${edu.accentColor}10; color: ${edu.accentColor}`}
                          >
                            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                            </svg>
                          </span>
                          <div>
                            <h4 class="text-sm font-semibold text-gray-800 leading-snug group-hover:text-black transition-colors">{act.role}</h4>
                            <p class="text-xs text-gray-550 leading-relaxed font-light mt-1">{act.desc}</p>
                          </div>
                        </li>
                      ))}
                    </ul>
                  </div>

                  <!-- Verified Document attachments list -->
                  {edu.documents.length > 0 && (
                    <div class="bg-white/60 border border-white/60 p-6 rounded-3xl shadow-[0_4px_20px_rgba(0,0,0,0.01)]">
                      <span class="text-[10px] font-semibold text-gray-400 uppercase tracking-widest block mb-4">Verified Credentials & Transcripts</span>
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        {edu.documents.map((doc) => (
                          <div 
                            class="document-preview-card border border-gray-200/70 bg-white/80 rounded-2xl p-4 flex items-center justify-between hover:border-gray-300 hover:shadow-sm transition-all duration-300 cursor-pointer group"
                            data-doc-name={doc.name}
                            data-doc-url={doc.url}
                            data-doc-type={doc.type}
                            data-doc-desc={doc.description}
                          >
                            <div class="flex items-center gap-3 overflow-hidden">
                              <!-- File Icon -->
                              <span class="w-10 h-10 rounded-xl bg-gray-50 flex items-center justify-center border border-gray-100 flex-shrink-0 text-gray-400 group-hover:text-gray-900 group-hover:bg-white transition-colors">
                                {doc.type === 'pdf' ? (
                                  <svg class="w-5.5 h-5.5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 9h1v1H9V9z" />
                                  </svg>
                                ) : doc.type === 'image' ? (
                                  <svg class="w-5.5 h-5.5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                  </svg>
                                ) : (
                                  <svg class="w-5.5 h-5.5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                  </svg>
                                )}
                              </span>
                              
                              <div class="overflow-hidden">
                                <h4 class="text-xs font-semibold text-gray-800 truncate group-hover:text-black transition-colors">{doc.name}</h4>
                                <span class="text-[9px] font-mono text-gray-400 block truncate uppercase">{doc.filename}</span>
                              </div>
                            </div>

                            <span class="w-7 h-7 rounded-full bg-gray-50 border border-gray-150 flex items-center justify-center text-gray-400 hover:text-gray-900 group-hover:scale-105 transition-transform flex-shrink-0">
                              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                              </svg>
                            </span>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  <!-- Fallback empty docs state for SLIIT HDip -->
                  {edu.documents.length === 0 && (
                    <div class="bg-white/40 border border-dashed border-gray-200 p-6 rounded-3xl shadow-[inset_0_1px_2px_rgba(0,0,0,0.01)] text-center flex flex-col justify-center items-center py-10 min-h-[140px]">
                      <div class="p-3 bg-blue-50/70 border border-blue-100 rounded-full text-blue-500 mb-3">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                      </div>
                      <h4 class="text-xs font-semibold text-gray-800">Pending Graduation Artifacts</h4>
                      <p class="text-[10px] text-gray-400 font-light leading-normal max-w-xs mt-1">Official transcripts and certification scrolls will be issued upon modular completion expected in 2027.</p>
                    </div>
                  )}
                </div>

              </div>

            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- Fullscreen Document Overlay Viewer Lightbox Modal -->
    <div id="document-lightbox" class="fixed inset-0 z-50 bg-black/80 backdrop-blur-md hidden justify-center items-center p-4">
      <!-- Lightbox Container Card -->
      <div class="bg-white rounded-[2rem] w-full max-w-5xl h-[85vh] flex flex-col relative overflow-hidden shadow-2xl scale-95 opacity-0 transition-all duration-300" id="lightbox-container">
        
        <!-- Header Panel -->
        <div class="px-6 py-4 border-b border-gray-150 flex items-center justify-between bg-white relative z-10">
          <div>
            <h3 class="font-san font-semibold text-gray-900 text-base" id="lightbox-doc-title">Document Viewer</h3>
            <p class="text-[11px] text-gray-500 font-light truncate max-w-md sm:max-w-xl" id="lightbox-doc-desc">Document verification details...</p>
          </div>

          <div class="flex items-center gap-2">
            <!-- Download Button -->
            <a 
              href="#" 
              download 
              id="lightbox-download-btn" 
              class="w-10 h-10 rounded-full bg-gray-50 border border-gray-150 text-gray-600 hover:text-black hover:bg-gray-100 flex items-center justify-center transition-colors cursor-pointer"
              title="Download File"
            >
              <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
            </a>

            <!-- Close Button -->
            <button 
              id="lightbox-close-btn" 
              class="w-10 h-10 rounded-full bg-gray-900 text-white hover:bg-gray-800 flex items-center justify-center transition-colors cursor-pointer"
              aria-label="Close viewer"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Render Content Area -->
        <div class="flex-1 w-full bg-gray-50 flex items-center justify-center overflow-auto p-4 relative" id="lightbox-content-wrapper">
          <!-- Dynamically filled with iframe or image tag -->
        </div>

      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  // Dynamic Dossier Toggle State Script
  const sidebarButtons = document.querySelectorAll(".sidebar-tab-btn");
  const mobileButtons = document.querySelectorAll(".mobile-tab-btn");
  const dossierSheets = document.querySelectorAll(".dossier-sheet");

  function switchDossierSheet(targetId: string) {
    // Hide all sheets and trigger animations
    dossierSheets.forEach((sheet) => {
      const el = sheet as HTMLElement;
      if (el.id === `sheet-${targetId}`) {
        el.classList.remove("hidden");
        // Force reflow
        el.offsetHeight;
        el.classList.add("block");
        setTimeout(() => {
          el.classList.remove("translate-y-4", "opacity-0");
        }, 20);
      } else {
        el.classList.add("hidden", "translate-y-4", "opacity-0");
        el.classList.remove("block");
      }
    });

    // Update Desktop Sidebar tabs
    sidebarButtons.forEach((btn) => {
      const button = btn as HTMLElement;
      const indicatorDot = document.getElementById(`dot-${button.getAttribute("data-target")}`);
      if (button.getAttribute("data-target") === targetId) {
        button.classList.remove("bg-white/40", "border-transparent", "text-gray-500");
        button.classList.add("bg-white", "border-white", "shadow-md", "shadow-gray-100/50", "scale-[1.02]", "text-gray-900", "active-tab");
        
        if (indicatorDot) {
          indicatorDot.classList.remove("bg-gray-300", "scale-75");
          indicatorDot.classList.add("bg-[#4285F4]", "scale-100", "ring-4", "ring-blue-100");
        }
      } else {
        button.classList.add("bg-white/40", "border-transparent", "text-gray-500");
        button.classList.remove("bg-white", "border-white", "shadow-md", "shadow-gray-100/50", "scale-[1.02]", "text-gray-900", "active-tab");
        
        if (indicatorDot) {
          indicatorDot.classList.add("bg-gray-300", "scale-75");
          indicatorDot.classList.remove("bg-[#4285F4]", "scale-100", "ring-4", "ring-blue-100");
        }
      }
    });

    // Update Mobile Tabs
    mobileButtons.forEach((btn) => {
      const button = btn as HTMLElement;
      if (button.getAttribute("data-target") === targetId) {
        button.classList.remove("bg-white/40", "text-gray-550", "border-gray-200/60");
        button.classList.add("bg-white", "text-gray-900", "border-[#4285F4]", "shadow-sm", "font-semibold", "active-tab");
      } else {
        button.classList.add("bg-white/40", "text-gray-550", "border-gray-200/60");
        button.classList.remove("bg-white", "text-gray-900", "border-[#4285F4]", "shadow-sm", "font-semibold", "active-tab");
      }
    });
  }

  // Bind desktop clicks
  sidebarButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const targetId = btn.getAttribute("data-target");
      if (targetId) switchDossierSheet(targetId);
    });
  });

  // Bind mobile clicks
  mobileButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const targetId = btn.getAttribute("data-target");
      if (targetId) switchDossierSheet(targetId);
    });
  });


  // Lightbox Media Viewer Dialog logic
  const docPreviewCards = document.querySelectorAll(".document-preview-card");
  const lightboxModal = document.getElementById("document-lightbox");
  const lightboxContainer = document.getElementById("lightbox-container");
  const closeBtn = document.getElementById("lightbox-close-btn");
  const docTitle = document.getElementById("lightbox-doc-title");
  const docDesc = document.getElementById("lightbox-doc-desc");
  const downloadBtn = document.getElementById("lightbox-download-btn") as HTMLAnchorElement;
  const contentWrapper = document.getElementById("lightbox-content-wrapper");

  function openLightbox(name: string, url: string, type: string, description: string) {
    if (!lightboxModal || !lightboxContainer || !docTitle || !docDesc || !downloadBtn || !contentWrapper) return;

    docTitle.textContent = name;
    docDesc.textContent = description;
    downloadBtn.href = url;

    // Clear content wrapper
    contentWrapper.innerHTML = "";

    // Show according to type
    if (type === 'pdf') {
      const iframe = document.createElement("iframe");
      iframe.src = url;
      iframe.className = "w-full h-full border-0 rounded-2xl bg-white shadow-inner";
      contentWrapper.appendChild(iframe);
    } else if (type === 'image') {
      const img = document.createElement("img");
      img.src = url;
      img.alt = name;
      img.className = "max-w-full max-h-full object-contain rounded-2xl shadow-md";
      contentWrapper.appendChild(img);
    } else if (type === 'link') {
      const linkCard = document.createElement("div");
      linkCard.className = "bg-white p-8 rounded-3xl border border-gray-150 max-w-md text-center flex flex-col items-center shadow-lg my-auto";
      linkCard.innerHTML = `
        <div class="w-16 h-16 bg-amber-500/10 text-amber-500 rounded-full flex items-center justify-center mb-4 border border-amber-100">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </div>
        <h3 class="font-san font-semibold text-gray-900 text-lg mb-2">Verified Result Portal</h3>
        <p class="text-xs text-gray-500 font-light leading-relaxed mb-6">
          This secondary credential is authenticated through the Ministry of Education results portal. Click below to verify manually.
        </p>
        <a href="${url}" target="_blank" class="px-6 py-2.5 bg-gray-900 hover:bg-gray-800 text-white rounded-full text-xs font-semibold transition-all inline-flex items-center gap-2">
          Open External Portal
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      `;
      contentWrapper.appendChild(linkCard);
    }

    // Toggle Modal visibility
    lightboxModal.classList.remove("hidden");
    lightboxModal.classList.add("flex");
    document.body.style.overflow = "hidden"; // Disable background scrolling

    // Trigger transitions
    setTimeout(() => {
      lightboxContainer.classList.remove("scale-95", "opacity-0");
    }, 10);
  }

  function closeLightbox() {
    if (!lightboxModal || !lightboxContainer || !contentWrapper) return;

    lightboxContainer.classList.add("scale-95", "opacity-0");
    
    setTimeout(() => {
      lightboxModal.classList.remove("flex");
      lightboxModal.classList.add("hidden");
      document.body.style.overflow = ""; // Restore scrolling
      contentWrapper.innerHTML = ""; // Clear iframe to stop pdf/media playback
    }, 250);
  }

  // Bind preview clicks
  docPreviewCards.forEach((card) => {
    card.addEventListener("click", () => {
      const name = card.getAttribute("data-doc-name") || "Document";
      const url = card.getAttribute("data-doc-url") || "";
      const type = card.getAttribute("data-doc-type") || "image";
      const description = card.getAttribute("data-doc-desc") || "";
      openLightbox(name, url, type, description);
    });
  });

  // Bind close button click
  if (closeBtn) closeBtn.addEventListener("click", closeLightbox);

  // Bind modal background click
  if (lightboxModal) {
    lightboxModal.addEventListener("click", (e) => {
      if (e.target === lightboxModal) closeLightbox();
    });
  }

  // Bind ESC key to close modal
  window.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && lightboxModal && !lightboxModal.classList.contains("hidden")) {
      closeLightbox();
    }
  });
</script>

<style>
  /* Floating bubbles keyframe animations */
  @keyframes float-bubble-1 {
    0% { transform: translateY(0px) translateX(0px) scale(1); }
    50% { transform: translateY(-40px) translateX(20px) scale(1.1); }
    100% { transform: translateY(0px) translateX(0px) scale(1); }
  }
  @keyframes float-bubble-2 {
    0% { transform: translateY(0px) translateX(0px) scale(1.05); }
    50% { transform: translateY(-30px) translateX(-25px) scale(0.95); }
    100% { transform: translateY(0px) translateX(0px) scale(1.05); }
  }
  @keyframes float-bubble-3 {
    0% { transform: translateY(0px) translateX(0px) rotate(0deg); }
    50% { transform: translateY(-20px) translateX(15px) rotate(180deg); }
    100% { transform: translateY(0px) translateX(0px) rotate(360deg); }
  }
  .animate-float-bubble-1 { animation: float-bubble-1 14s ease-in-out infinite; }
  .animate-float-bubble-2 { animation: float-bubble-2 16s ease-in-out infinite; }
  .animate-float-bubble-3 { animation: float-bubble-3 18s ease-in-out infinite; }

  /* Custom styling for skills hover border effects */
  span[style*="--hover-accent"] {
    transition: all 0.2s ease;
  }
  span[style*="--hover-accent"]:hover {
    border-color: var(--hover-accent);
    color: #111111;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px var(--hover-accent)12;
  }

  /* Custom scrollbar hide for mobile tabs list */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>
