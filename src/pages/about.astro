    0% { transform: translateY(0px) translateX(0px) scale(1); }
    50% { transform: translateY(-30px) translateX(15px) scale(1.08); }
    100% { transform: translateY(0px) translateX(0px) scale(1); }
  }
  @keyframes float-bubble-2 {
    0% { transform: translateY(0px) translateX(0px) scale(1.05); }
    50% { transform: translateY(-25px) translateX(-20px) scale(0.95); }
    100% { transform: translateY(0px) translateX(0px) scale(1.05); }
  }
  @keyframes float-bubble-3 {
    0% { transform: translateY(0px) translateX(0px) rotate(0deg); }
    50% { transform: translateY(-15px) translateX(10px) rotate(180deg); }
    100% { transform: translateY(0px) translateX(0px) rotate(360deg); }
  }
  .animate-float-bubble-1 { animation: float-bubble-1 12s ease-in-out infinite; }
  .animate-float-bubble-2 { animation: float-bubble-2 15s ease-in-out infinite; }
  .animate-float-bubble-3 { animation: float-bubble-3 16s ease-in-out infinite; }

  /* Morphing Liquid Monogram Keyframes */
  @keyframes morph-liquid {
    0% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
    50% { border-radius: 30% 60% 70% 30% / 50% 60% 30% 50%; }
    100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
  }
  .animate-morph-liquid {
    animation: morph-liquid 8s ease-in-out infinite;
  }

  .liquid-monogram {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.45) 0%, rgba(255, 255, 255, 0.1) 100%);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  /* Liquid Glass cards inside About page */
  .liquid-about-card {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.5) 0%, rgba(255, 255, 255, 0.15) 100%);
    backdrop-filter: blur(24px) saturate(190%);
    -webkit-backdrop-filter: blur(24px) saturate(190%);
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 
      inset 0 1.5px 0 rgba(255, 255, 255, 0.75), 
      inset 0 -1.5px 0 rgba(0, 0, 0, 0.05),
      0 8px 28px -8px rgba(0, 0, 0, 0.03),
      0 1px 3px rgba(0, 0, 0, 0.01);
    border-radius: 2.2rem;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .liquid-about-card:hover {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.6) 0%, rgba(255, 255, 255, 0.2) 100%);
    border-color: rgba(255, 255, 255, 0.65);
    box-shadow: 
