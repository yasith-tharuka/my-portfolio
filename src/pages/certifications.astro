---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import { certificationsData } from "../data/certificationsData";

const { title, description, categories, certifications, emblemBadge, heroAccent, heroTitle, heroDescription, returnHomeText } = certificationsData;
---

<Layout title={title}>
  <main class="w-full min-h-screen bg-[#FAFAFC] relative overflow-hidden pt-12 pb-24 font-body">
    <!-- Interactive Background "Water Bubble Magic" droplets for liquid refraction -->
    <div class="absolute top-10 left-5 w-60 h-60 rounded-full bg-blue-400/18 blur-3xl animate-float-bubble-1 pointer-events-none"></div>
    <div class="absolute bottom-10 right-5 w-72 h-72 rounded-full bg-emerald-400/15 blur-3xl animate-float-bubble-2 pointer-events-none"></div>
    <div class="absolute top-1/3 left-1/4 w-44 h-44 rounded-full bg-amber-400/10 blur-3xl animate-float-bubble-3 pointer-events-none"></div>
    <div class="absolute bottom-1/3 right-1/4 w-48 h-48 rounded-full bg-purple-400/10 blur-3xl animate-float-bubble-2 pointer-events-none"></div>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-6 mb-16 relative z-20">
      <div class="flex flex-col md:flex-row md:items-start justify-between gap-8 pb-10 border-b border-white/20">
        <!-- Left: Sleek, large heading & descriptive subtext -->
        <div class="max-w-3xl">
          <span class="text-xs font-semibold text-[#4285F4] uppercase tracking-widest block mb-3 font-san">{heroAccent}</span>
          <h1 class="font-san text-4xl sm:text-5xl font-normal text-gray-900 tracking-tight leading-tight mb-4">
            {heroTitle}
          </h1>
          <p class="text-base sm:text-lg text-gray-550 leading-relaxed font-light">
            {heroDescription}
          </p>
        </div>
        <!-- Right: Pill button -->
        <div class="flex-shrink-0 mt-4 md:mt-2">
          <a
            href="/"
            class="inline-flex items-center gap-2 bg-white/20 hover:bg-white/35 text-gray-900 hover:text-black px-6 py-2.5 rounded-full text-xs sm:text-sm font-medium transition-all duration-200 hover:-translate-y-0.5 font-san border border-white/30 hover:border-white/50 shadow-sm backdrop-blur-md"
            id="back-home-button"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
               <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            {returnHomeText}
          </a>
        </div>
      </div>
    </section>

    <!-- Interactive Category Filter Tabs -->
    <section class="max-w-7xl mx-auto px-6 mb-12 relative z-20">
      <div class="flex flex-wrap gap-2.5 md:gap-3.5" id="filter-tabs-container">
        {categories.map((cat, idx) => (
          <button
            data-filter={cat.id}
            class={`filter-tab px-5 py-2.5 rounded-full text-xs sm:text-sm font-medium border transition-all duration-300 cursor-pointer font-san ${
              idx === 0
                ? "bg-white/40 text-black border-white/50 shadow-sm backdrop-blur-md active-all"
                : "bg-white/10 text-gray-700 border-white/20 hover:bg-white/30 hover:border-white/40 hover:text-black shadow-sm backdrop-blur-md"
            }`}
            id={`tab-btn-${cat.id}`}
          >
            {cat.name}
          </button>
        ))}
      </div>
    </section>

    <!-- Certifications Grid -->
    <section class="max-w-7xl mx-auto px-6 relative z-20">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10 transition-all duration-300" id="certs-grid">
        {certifications.map((cert, idx) => (
          <div
            data-category={cert.category}
            data-index={idx}
            class="cert-card relative bg-white/20 backdrop-blur-xl rounded-[2.2rem] border border-white/45 p-6 md:p-8 flex flex-col justify-between transition-all duration-300 hover:shadow-lg hover:border-white/60 hover:-translate-y-1 hover:bg-white/30 group shadow-sm overflow-hidden shadow-[inset_0_1px_2px_rgba(255,255,255,0.65),0_8px_32px_rgba(0,0,0,0.02)] cursor-pointer"
            id={`cert-card-${idx}`}
          >
            <!-- Accent bubble glow overlay -->
            <div 
              class="absolute -top-10 -left-10 w-24 h-24 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-2xl pointer-events-none"
              style={`background-color: ${
                cert.category === "cs-engineering" ? "#4285F4" :
                cert.category === "cloud" ? "#8B5CF6" :
                cert.category === "leadership-impact" ? "#FBBC05" :
                cert.category === "memberships" ? "#34A853" :
                cert.category === "extracurricular" ? "#EA4335" : "#4285F4"
              }25`}
            ></div>

            <!-- Hover Arrow indicator -->
            <span class="absolute top-6 right-6 text-gray-400 group-hover:text-gray-900 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 pointer-events-none z-10">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </span>

            <div>
              <!-- Issuer Logo (Google/Harvard/etc.) in Top Header -->
              <div class="mb-6 flex items-center justify-between relative z-10">
                <span class="w-12 h-12 flex items-center justify-center bg-white/50 border border-white/50 backdrop-blur-md rounded-2xl shadow-sm p-1.5 flex-shrink-0 transition-all duration-300 group-hover:rounded-[1.1rem] issuer-logo-wrapper overflow-hidden">
                  <img
                    src={`/certificates/Issuer_Logos/${cert.issuerLogo}`}
                    alt={`${cert.issuer} Logo`}
                    class="w-full h-full object-contain"
                    loading="lazy"
                  />
                </span>
                
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-widest mr-8">
                  {cert.category === "cs-engineering" && "Tech & CS"}
                  {cert.category === "cloud" && "Cloud"}
                  {cert.category === "leadership-impact" && "Leadership"}
                  {cert.category === "memberships" && "Membership"}
                  {cert.category === "extracurricular" && "Activities"}
                </span>
              </div>

              <!-- Title & Organization -->
              <h3 class="font-san text-xl font-medium text-gray-900 leading-snug mb-2 relative z-10">
                {cert.title}
              </h3>
              
              <div class="flex items-wrap items-center gap-2 mb-4 relative z-10">
                <span class="text-sm font-semibold text-gray-700">{cert.issuer}</span>
                <span class="text-xs text-gray-400 font-bold">•</span>
                <span class="text-xs font-medium text-gray-500">{cert.date}</span>
              </div>

              <!-- Description -->
              <p class="text-sm text-gray-650 leading-relaxed mb-6 font-light relative z-10">
                {cert.description}
              </p>

              {/* Skills Tags */}
              {cert.skills && cert.skills.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mb-6 relative z-10">
                  {cert.skills.map((skill) => (
                    <span class="bg-white/40 text-gray-755 border border-white/50 text-[11px] px-2.5 py-0.5 rounded-full font-medium shadow-sm backdrop-blur-sm">
                      {skill}
                    </span>
                  ))}
                </div>
              )}
            </div>

            <!-- Bottom Section (Verification / ID) -->
            <div class="pt-4 border-t border-white/20 flex items-center justify-between mt-auto relative z-10">
              {cert.credentialId ? (
                <span class="text-xs font-mono text-gray-500">
                  {cert.credentialId}
                </span>
              ) : (
                <span class="text-xs text-gray-400 italic font-light">
                  View Proof Details
                </span>
              )}

              <span class="inline-flex items-center gap-1 text-xs font-semibold text-blue-600 group-hover:text-blue-800 transition-colors">
                View Proof
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Detailed Modal Panel Overlay (Horizontal Split "Small Tab" Design) -->
    <div
      id="cert-modal-backdrop"
      class="fixed inset-0 bg-black/60 backdrop-blur-md z-50 flex items-center justify-center p-4 md:p-6 opacity-0 pointer-events-none transition-all duration-300"
    >
      <!-- Modal Box: Details left, Cert image right -->
      <div
        id="cert-modal-box"
        class="relative w-full max-w-4xl bg-white/80 backdrop-blur-2xl rounded-3xl overflow-hidden shadow-2xl transform scale-95 opacity-0 transition-all duration-300 grid grid-cols-1 md:grid-cols-12 min-h-[400px] md:min-h-[500px] border border-white/40"
      >
        <!-- Close button inside the modal box -->
        <button
          id="cert-modal-close"
          class="absolute top-5 right-5 z-10 w-10 h-10 bg-white/20 hover:bg-white/45 text-gray-800 rounded-full flex items-center justify-center transition-colors cursor-pointer border border-white/30 backdrop-blur-sm"
          aria-label="Close panel"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

        <!-- Left Column: Details (7 cols out of 12) -->
        <div class="col-span-12 md:col-span-7 p-8 md:p-10 flex flex-col justify-between relative z-10">
          <div>
            <!-- Issuer Logo Header -->
            <div class="flex items-center justify-between mb-6">
              <div id="modal-logo-container" class="w-12 h-12 flex items-center justify-center bg-white/50 border border-white/50 backdrop-blur-md rounded-2xl shadow-sm p-1.5 overflow-hidden">
                <!-- Dynamic img logo cloned here -->
              </div>
              <span id="modal-category-badge" class="text-xs font-semibold text-blue-600 uppercase tracking-widest mr-8">
                <!-- Dynamic Category Badge injected here -->
              </span>
            </div>

            <!-- Title -->
            <h2 id="modal-title" class="font-san text-2xl md:text-3xl font-medium text-gray-900 leading-snug mb-3">
              <!-- Title injected here -->
            </h2>

            <!-- Issuer & Date info -->
            <div class="flex items-center gap-2.5 mb-6 text-sm text-gray-655 font-normal">
              <span id="modal-issuer" class="font-semibold text-gray-800"></span>
              <span class="text-gray-400 font-bold">•</span>
              <span id="modal-date" class="font-medium text-gray-500"></span>
            </div>

            <!-- Description -->
            <p id="modal-description" class="text-sm md:text-base text-gray-655 leading-relaxed font-light mb-8">
              <!-- Description injected here -->
            </p>

            <!-- Skills list tags -->
            <div class="mb-8">
              <h4 class="text-xs font-semibold text-gray-450 uppercase tracking-wider mb-3">Skills & Technologies</h4>
              <div id="modal-skills-container" class="flex flex-wrap gap-2">
                <!-- Skills badges dynamically injected -->
              </div>
            </div>
          </div>

          <!-- Footer section with credential ID & link -->
          <div class="pt-6 border-t border-white/20 flex items-center justify-between mt-auto">
            <div>
              <span class="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-0.5">Credential ID</span>
              <span id="modal-credential-id" class="text-xs font-mono text-gray-655 font-medium"></span>
            </div>

            <a
              id="modal-verify-btn"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-white/20 hover:bg-white/35 text-gray-900 hover:text-black border border-white/30 hover:border-white/50 px-6 py-3 rounded-full text-xs font-semibold transition-all duration-200 shadow-sm backdrop-blur-md"
            >
              Verify Credential
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Right Column: Proof Image (5 cols out of 12) -->
        <div id="modal-proof-column" class="col-span-12 md:col-span-5 bg-white/40 backdrop-blur-md border-t md:border-t-0 md:border-l border-white/20 flex items-center justify-center p-6 md:p-8 min-h-[300px] md:min-h-0">
          <!-- Container for Certificate Image or Emblem Badge -->
          <div id="modal-proof-container" class="w-full h-full flex items-center justify-center">
            <!-- Dynamic Proof content injected here -->
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  /* Floating bubbles keyframe animations */
  @keyframes float-bubble-1 {
    0% { transform: translateY(0px) translateX(0px) scale(1); }
    50% { transform: translateY(-40px) translateX(20px) scale(1.1); }
    100% { transform: translateY(0px) translateX(0px) scale(1); }
  }
  @keyframes float-bubble-2 {
    0% { transform: translateY(0px) translateX(0px) scale(1.05); }
    50% { transform: translateY(-30px) translateX(-25px) scale(0.95); }
    100% { transform: translateY(0px) translateX(0px) scale(1.05); }
  }
  @keyframes float-bubble-3 {
    0% { transform: translateY(0px) translateX(0px) rotate(0deg); }
    50% { transform: translateY(-20px) translateX(15px) rotate(180deg); }
    100% { transform: translateY(0px) translateX(0px) rotate(360deg); }
  }
  .animate-float-bubble-1 { animation: float-bubble-1 14s ease-in-out infinite; }
  .animate-float-bubble-2 { animation: float-bubble-2 16s ease-in-out infinite; }
  .animate-float-bubble-3 { animation: float-bubble-3 18s ease-in-out infinite; }

  /* Smooth card state configurations */
  .cert-card {
    transition: opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1), transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.25s ease, box-shadow 0.25s ease, background-color 0.25s ease;
  }
  .cert-card.card-filtered-out {
    opacity: 0;
    transform: scale(0.96) translateY(12px);
    pointer-events: none;
    position: absolute;
    width: 0;
    height: 0;
    padding: 0;
    margin: 0;
    border: none;
    overflow: hidden;
  }

  /* Active states for glassmorphic tabs */
  .filter-tab {
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .filter-tab.active-all {
    background-color: rgba(255, 255, 255, 0.4);
    color: #000000;
    border-color: rgba(255, 255, 255, 0.65);
    box-shadow: 0 4px 14px rgba(255, 255, 255, 0.15);
  }
  .filter-tab.active-tab-blue {
    background-color: rgba(66, 133, 244, 0.12);
    color: #1a73e8;
    border-color: rgba(66, 133, 244, 0.35);
    box-shadow: 0 4px 14px rgba(66, 133, 244, 0.12);
  }
  .filter-tab.active-tab-purple {
    background-color: rgba(139, 92, 246, 0.12);
    color: #7c3aed;
    border-color: rgba(139, 92, 246, 0.35);
    box-shadow: 0 4px 14px rgba(139, 92, 246, 0.12);
  }
  .filter-tab.active-tab-green {
    background-color: rgba(52, 168, 83, 0.1);
    color: #137333;
    border-color: rgba(52, 168, 83, 0.3);
    box-shadow: 0 4px 14px rgba(52, 168, 83, 0.1);
  }
  .filter-tab.active-tab-amber {
    background-color: rgba(251, 188, 5, 0.1);
    color: #b06000;
    border-color: rgba(251, 188, 5, 0.35);
    box-shadow: 0 4px 14px rgba(251, 188, 5, 0.1);
    border-color: rgba(251, 188, 5, 0.4);
    box-shadow: 0 4px 14px rgba(251, 188, 5, 0.15);
  }
  .filter-tab.active-tab-red {
    background-color: rgba(234, 67, 53, 0.2);
    color: #c5221f;
    border-color: rgba(234, 67, 53, 0.4);
    box-shadow: 0 4px 14px rgba(234, 67, 53, 0.15);
  }
</style>

<script define:vars={{ certifications, emblemBadge }}>
  // Client-side scripting for interactive filter tabs & details modal
  document.addEventListener("DOMContentLoaded", () => {
    const tabs = document.querySelectorAll(".filter-tab");
    const cards = document.querySelectorAll(".cert-card");
    
    // Modal elements
    const backdrop = document.getElementById("cert-modal-backdrop");
    const box = document.getElementById("cert-modal-box");
    const closeBtn = document.getElementById("cert-modal-close");
    
    const modalLogo = document.getElementById("modal-logo-container");
    const modalCatBadge = document.getElementById("modal-category-badge");
    const modalTitle = document.getElementById("modal-title");
    const modalIssuer = document.getElementById("modal-issuer");
    const modalDate = document.getElementById("modal-date");
    const modalDesc = document.getElementById("modal-description");
    const modalSkills = document.getElementById("modal-skills-container");
    const modalCredId = document.getElementById("modal-credential-id");
    const modalVerifyBtn = document.getElementById("modal-verify-btn");
    const modalProofContainer = document.getElementById("modal-proof-container");

    const catLabels = {
      "cs-engineering": "Tech & CS",
      "cloud": "Cloud",
      "leadership-impact": "Leadership",
      "memberships": "Membership",
      "extracurricular": "Activities"
    };

    // --- Tab Filtering Logic ---
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const filterValue = tab.getAttribute("data-filter");

        // Clear active styles (Glass tabs format)
        tabs.forEach((t) => {
          t.className = "filter-tab px-5 py-2.5 rounded-full text-xs sm:text-sm font-medium border border-white/20 bg-white/10 text-gray-700 hover:bg-white/30 hover:border-white/40 hover:text-black shadow-sm backdrop-blur-md transition-all duration-300 cursor-pointer font-sans";
        });

        // Add correct color classes
        if (filterValue === "all") {
          tab.classList.add("active-all");
          tab.classList.remove("bg-white/10", "text-gray-700", "border-white/20");
        } else if (filterValue === "cs-engineering") {
          tab.classList.add("active-tab-blue");
          tab.classList.remove("bg-white/10", "text-gray-700", "border-white/20");
        } else if (filterValue === "cloud") {
          tab.classList.add("active-tab-purple");
          tab.classList.remove("bg-white/10", "text-gray-700", "border-white/20");
        } else if (filterValue === "leadership-impact") {
          tab.classList.add("active-tab-amber");
          tab.classList.remove("bg-white/10", "text-gray-700", "border-white/20");
        } else if (filterValue === "memberships") {
          tab.classList.add("active-tab-green");
          tab.classList.remove("bg-white/10", "text-gray-700", "border-white/20");
        } else if (filterValue === "extracurricular") {
          tab.classList.add("active-tab-red");
          tab.classList.remove("bg-white/10", "text-gray-700", "border-white/20");
        }

        // Filter cards
        cards.forEach((card) => {
          const cardCategory = card.getAttribute("data-category");
          
          if (filterValue === "all" || cardCategory === filterValue) {
            card.classList.remove("card-filtered-out");
            card.style.display = "flex";
          } else {
            card.classList.add("card-filtered-out");
            setTimeout(() => {
              if (card.classList.contains("card-filtered-out")) {
                card.style.display = "none";
              }
            }, 300);
          }
        });
      });
    });

    // --- Modal Open/Close Logic ---
    function openModal() {
      if (backdrop && box) {
        backdrop.classList.remove("opacity-0", "pointer-events-none");
        backdrop.classList.add("opacity-100");
        box.classList.remove("scale-95", "opacity-0");
        box.classList.add("scale-100", "opacity-100");
        document.body.style.overflow = "hidden";
      }
    }

    function closeModal() {
      if (backdrop && box) {
        backdrop.classList.remove("opacity-100");
        backdrop.classList.add("opacity-0", "pointer-events-none");
        box.classList.remove("scale-100", "opacity-100");
        box.classList.add("scale-95", "opacity-0");
        document.body.style.overflow = "";
      }
    }

    // Populate and open modal on card click
    cards.forEach((card) => {
      card.addEventListener("click", () => {
        const index = parseInt(card.getAttribute("data-index") || "0", 10);
        const cert = certifications[index];

        // Clone the logo from the card directly to the modal
        const logoWrapper = card.querySelector(".issuer-logo-wrapper img");
        if (logoWrapper && modalLogo) {
          modalLogo.innerHTML = `<img src="${logoWrapper.getAttribute('src')}" alt="${logoWrapper.getAttribute('alt')}" class="w-full h-full object-contain" />`;
        }

        // Set text content
        if (modalTitle) modalTitle.textContent = cert.title;
        if (modalIssuer) modalIssuer.textContent = cert.issuer;
        if (modalDate) modalDate.textContent = cert.date;
        if (modalDesc) modalDesc.textContent = cert.description;
        if (modalCatBadge) modalCatBadge.textContent = catLabels[cert.category] || "";

        // Build skills tags
        if (modalSkills) {
          modalSkills.innerHTML = "";
          if (cert.skills && cert.skills.length > 0) {
            cert.skills.forEach(skill => {
              const span = document.createElement("span");
              span.className = "bg-white/40 text-gray-750 border border-white/50 text-[11px] px-2.5 py-0.5 rounded-full font-medium shadow-sm backdrop-blur-sm";
              span.textContent = skill;
              modalSkills.appendChild(span);
            });
          }
        }

        // Set Credential ID
        if (modalCredId) {
          modalCredId.textContent = cert.credentialId || "Not Applicable";
        }

        // Verify URL Button
        if (modalVerifyBtn) {
          if (cert.verifyUrl) {
            modalVerifyBtn.style.display = "inline-flex";
            modalVerifyBtn.setAttribute("href", cert.verifyUrl);
          } else {
            modalVerifyBtn.style.display = "none";
          }
        }

        // Proof Content: Image or Embellished Emblem Fallback
        if (modalProofContainer) {
          if (cert.proofImage) {
            modalProofContainer.innerHTML = `
              <div class="relative w-full h-full flex items-center justify-center max-h-[300px] md:max-h-[380px] rounded-2xl overflow-hidden border border-white/30 bg-white/40 shadow-sm p-3 backdrop-blur-sm shadow-[inset_0_1px_2px_rgba(255,255,255,0.7)]">
                <img 
                  src="${cert.proofImage}" 
                  alt="${cert.title} Proof" 
                  class="w-full h-full object-contain rounded-xl hover:scale-[1.02] transition-transform duration-300"
                  loading="lazy"
                />
              </div>
            `;
          } else {
            modalProofContainer.innerHTML = emblemBadge;
          }
        }

        openModal();
      });
    });

    // Close button interactions
    if (closeBtn) closeBtn.addEventListener("click", closeModal);
    if (backdrop) {
      backdrop.addEventListener("click", (e) => {
        if (e.target === backdrop) closeModal();
      });
    }
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });
  });
</script>
