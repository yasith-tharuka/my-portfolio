---
// src/pages/volunteer.astro
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Volunteer from "../components/Volunteer.astro";

const title = "Volunteer Experience | Yasith Tharuka";
---

<Layout title={title}>
  <main class="w-full pt-12 bg-[#FAFAFC] relative min-h-screen">
    <!-- Bubble glow decoration inside the page wrapper -->
    <div class="absolute top-20 right-10 w-96 h-96 rounded-full bg-blue-300/5 blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-20 left-10 w-96 h-96 rounded-full bg-emerald-300/5 blur-3xl pointer-events-none"></div>

    <!-- Render the Volunteer component (no limit, displays all 10, manages its own header & Return button) -->
    <Volunteer />
  </main>
  <Footer />
</Layout>
