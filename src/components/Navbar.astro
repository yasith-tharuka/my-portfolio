<script>
    console.log("Navbar JS executing...");

    // Map each button to its corresponding menu ID
    const dropdownConfigs = [
        {
            btnId: "background-menu-btn",
            menuId: "background-mega-menu",
            arrowId: "background-arrow",
        },
        {
            btnId: "resources-menu-btn",
            menuId: "resources-mega-menu",
            arrowId: "resources-arrow",
        },
    ];

    let activeMenuId: string | null = null;
    let hideTimeout: any = null;

    function getArrowId(menuId: string) {
        const config = dropdownConfigs.find((c) => c.menuId === menuId);
        return config ? config.arrowId : "";
    }

    function openMenu(menuId: string) {
        if (hideTimeout) {
            clearTimeout(hideTimeout);
            hideTimeout = null;
        }

        if (activeMenuId === menuId) return;

        // If another menu is already open, close it immediately without transition
        if (activeMenuId) {
            closeMenuImmediately(activeMenuId);
        }

        activeMenuId = menuId;
        const menu = document.getElementById(menuId);
        const arrowId = getArrowId(menuId);
        const arrow = arrowId ? document.getElementById(arrowId) : null;

        if (menu) {
            menu.classList.remove("hidden");
            // Set body background for overlay effect
            document.body.style.backgroundColor = "#EDEDED";

            // Trigger transition
            setTimeout(() => {
                if (activeMenuId === menuId) {
                    menu.classList.remove("opacity-0", "-translate-y-2");
                    if (arrow) {
                        arrow.classList.add("rotate-180");
                    }
                }
            }, 20);
        }
    }

    function closeMenuImmediately(menuId: string) {
        const menu = document.getElementById(menuId);
        const arrowId = getArrowId(menuId);
        const arrow = arrowId ? document.getElementById(arrowId) : null;
        if (menu) {
            menu.classList.add("hidden", "opacity-0", "-translate-y-2");
        }
        if (arrow) {
            arrow.classList.remove("rotate-180");
        }
    }

    function closeActiveMenu() {
        if (!activeMenuId) return;

        const menuId = activeMenuId;
        activeMenuId = null;

        const menu = document.getElementById(menuId);
        const arrowId = getArrowId(menuId);
        const arrow = arrowId ? document.getElementById(arrowId) : null;

        if (menu) {
            menu.classList.add("opacity-0", "-translate-y-2");
            if (arrow) {
                arrow.classList.remove("rotate-180");
            }
            document.body.style.backgroundColor = "";

            setTimeout(() => {
                // Only hide if no other menu has been opened in the meantime
                if (activeMenuId !== menuId) {
                    menu.classList.add("hidden");
                }
            }, 200);
        }
    }

    function requestHide() {
        if (hideTimeout) clearTimeout(hideTimeout);
        hideTimeout = setTimeout(() => {
            closeActiveMenu();
        }, 150);
    }

    function cancelHide() {
        if (hideTimeout) {
            clearTimeout(hideTimeout);
            hideTimeout = null;
        }
    }

    // Set up listeners for all dropdown configs
    dropdownConfigs.forEach(({ btnId, menuId }) => {
        const btn = document.getElementById(btnId);
        const menu = document.getElementById(menuId);

        if (btn && menu) {
            // Trigger button hover events
            btn.addEventListener("mouseenter", () => {
                openMenu(menuId);
            });
            btn.addEventListener("mouseleave", () => {
                requestHide();
            });

            // Mega menu hover events
            menu.addEventListener("mouseenter", () => {
                cancelHide();
                openMenu(menuId);
            });
            menu.addEventListener("mouseleave", () => {
                requestHide();
            });
        }
    });

    // Close menu when hovering non-dropdown navigation links
    const allLinks = document.querySelectorAll("nav a, nav button, header a");
    allLinks.forEach((link) => {
        // Exclude links inside any mega menu or mobile menu overlay
        if (
            link.closest("[id$='-mega-menu']") ||
            link.closest("#mobile-menu-overlay")
        ) {
            return;
        }
        const isDropdownBtn = dropdownConfigs.some((c) => c.btnId === link.id);
        if (!isDropdownBtn) {
            link.addEventListener("mouseenter", () => {
                closeActiveMenu();
            });
        }
    });

    // --- Mobile Menu Toggle logic ---
    const mobileMenuToggle = document.getElementById("mobile-menu-toggle");
    const mobileMenuClose = document.getElementById("mobile-menu-close");
    const mobileMenuOverlay = document.getElementById("mobile-menu-overlay");

    function openMobileMenu() {
        if (!mobileMenuOverlay) return;

        // Hide hamburger, show close button
        if (mobileMenuToggle) mobileMenuToggle.classList.add("hidden");
        if (mobileMenuClose) mobileMenuClose.classList.remove("hidden");

        // Show overlay
        mobileMenuOverlay.classList.remove("hidden");
        document.body.style.overflow = "hidden";

        setTimeout(() => {
            mobileMenuOverlay.classList.remove("opacity-0", "translate-y-4");
        }, 10);
    }

    function closeMobileMenu() {
        if (!mobileMenuOverlay) return;

        // Show hamburger, hide close button
        if (mobileMenuToggle) mobileMenuToggle.classList.remove("hidden");
        if (mobileMenuClose) mobileMenuClose.classList.add("hidden");

        // Hide overlay with transition
        mobileMenuOverlay.classList.add("opacity-0", "translate-y-4");
        document.body.style.overflow = "";

        setTimeout(() => {
            if (mobileMenuOverlay.classList.contains("opacity-0")) {
                mobileMenuOverlay.classList.add("hidden");
            }
        }, 300);
    }

    if (mobileMenuToggle) {
        mobileMenuToggle.addEventListener("click", openMobileMenu);
    }
    if (mobileMenuClose) {
        mobileMenuClose.addEventListener("click", closeMobileMenu);
    }

    // Close menu when clicking on any link inside the mobile menu
    const mobileMenuLinks = document.querySelectorAll(".mobile-menu-link");
    mobileMenuLinks.forEach((link) => {
        link.addEventListener("click", () => {
            closeMobileMenu();
        });
    });

    // Close menu on resize above md breakpoint
    window.addEventListener("resize", () => {
        if (window.innerWidth >= 768) {
            // 768px is md breakpoint
            if (
                mobileMenuOverlay &&
                !mobileMenuOverlay.classList.contains("hidden")
            ) {
                closeMobileMenu();
            }
        }
    });

    // --- Mobile Accordion Toggle logic ---
    const accordionToggles = document.querySelectorAll(
        ".mobile-accordion-toggle",
    );
    accordionToggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
            const targetId = toggle.getAttribute("data-target");
            const submenu = targetId ? document.getElementById(targetId) : null;
            const arrow = toggle.querySelector(".mobile-arrow");

            if (submenu) {
                const isOpen =
                    !submenu.classList.contains("hidden") &&
                    submenu.style.maxHeight &&
                    submenu.style.maxHeight !== "0px";

                if (isOpen) {
                    // Close
                    submenu.style.maxHeight = "0px";
                    if (arrow) arrow.classList.remove("rotate-180");
                    setTimeout(() => {
                        submenu.classList.add("hidden");
                    }, 300);
                } else {
                    // Open
                    submenu.classList.remove("hidden");
                    // Force reflow
                    submenu.offsetHeight;
                    submenu.style.maxHeight = submenu.scrollHeight + "px";
                    if (arrow) arrow.classList.add("rotate-180");
                }
            }
        });
    });
</script>
