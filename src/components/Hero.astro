---
// src/components/Hero.astro
import { heroData } from "../data/heroData";

const { typedName, typedTitle, description, ctaProjectsText, ctaContactText, ctaSummaryText, slides, quickSummary } = heroData;
---

<section
    id="hero-section"
    class="relative w-full overflow-hidden py-16 md:py-24 flex items-center justify-center border-b border-gray-100 min-h-[85vh]"
>
    <!-- Particle Canvas Overlay -->
    <canvas
        id="particle-canvas"
        class="absolute inset-0 w-full h-full pointer-events-none z-10 block"
    ></canvas>

    <div
        class="relative z-20 max-w-7xl mx-auto px-6 w-full grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-center"
    >
        <!-- Left Side: Interactive Slide Show (First on desktop, second on mobile) -->
        <div
            id="slideshow-wrapper"
            class="col-span-1 md:col-span-6 order-2 md:order-1 flex flex-col items-center justify-center relative min-h-[350px] md:min-h-[450px]"
        >
            <div id="projects" class="absolute -top-20"></div>
            <!-- Slide Container -->
            <div
                id="slides-container"
                class="relative w-full max-w-lg aspect-[4/3] rounded-2xl border border-gray-150 bg-[#F8F9FA] shadow-md overflow-hidden flex items-center justify-center"
            >
                <!-- Slide 1: Web Interface -->
                <div
                    class="slide absolute inset-0 opacity-100 transition-opacity duration-700 flex flex-col p-4 bg-white"
                    data-index="0"
                >
                    <!-- Browser Chrome -->
                    <div
                        class="flex items-center gap-1.5 border-b border-gray-100 pb-3 mb-4"
                    >
                        <div class="w-3.5 h-3.5 rounded-full bg-[#EA4335]">
                        </div>
                        <div class="w-3.5 h-3.5 rounded-full bg-[#FBBC05]">
                        </div>
                        <div class="w-3.5 h-3.5 rounded-full bg-[#34A853]">
                        </div>
                        <div
                            class="ml-4 flex-1 bg-[#F1F3F4] rounded-md h-5 text-[10px] text-gray-400 flex items-center px-3 font-mono"
                        >
                            {slides[0].path}
                        </div>
                    </div>
                    <!-- Web Page Content -->
                    <div
                        class="flex-1 w-full h-full overflow-hidden rounded-lg"
                    >
                        <img
                            src={slides[0].image}
                            alt={slides[0].alt}
                            class="w-full h-full object-cover"
                        />
                    </div>
                </div>

                <!-- Slide 2: Certificates -->
                <div
                    class="slide absolute inset-0 opacity-0 transition-opacity duration-700 flex flex-col p-4 bg-black"
                    data-index="1"
                >
                    <!-- Browser Chrome -->
                    <div
                        class="flex items-center gap-1.5 border-b border-zinc-800 pb-3 mb-4"
                    >
                        <div class="w-3.5 h-3.5 rounded-full bg-[#EA4335]">
                        </div>
                        <div class="w-3.5 h-3.5 rounded-full bg-[#FBBC05]">
                        </div>
                        <div class="w-3.5 h-3.5 rounded-full bg-[#34A853]">
                        </div>
                        <div
                            class="ml-4 flex-1 bg-zinc-900 rounded-md h-5 text-[10px] text-zinc-500 flex items-center px-3 font-mono"
                        >
                            {slides[1].path}
                        </div>
                    </div>
                    <!-- Web Page Content -->
                    <div
                        class="flex-1 w-full h-full overflow-hidden rounded-lg bg-black"
                    >
                        <img
                            src={slides[1].image}
                            alt={slides[1].alt}
                            class="w-full h-full object-cover"
                        />
                    </div>
                </div>

                <!-- Slide 3: Terminal -->
                <div
                    class="slide absolute inset-0 opacity-0 transition-opacity duration-700 flex flex-col p-4 bg-[#070B19]"
                    data-index="2"
                >
                    <!-- Terminal Chrome -->
                    <div
                        class="flex items-center gap-1.5 border-b border-[#1E293B] pb-3 mb-4"
                    >
                        <div class="w-3.5 h-3.5 rounded-full bg-[#EA4335]">
                        </div>
                        <div class="w-3.5 h-3.5 rounded-full bg-[#FBBC05]">
                        </div>
                        <div class="w-3.5 h-3.5 rounded-full bg-[#34A853]">
                        </div>
                        <span class="ml-4 text-xs font-mono text-gray-500"
                            >{slides[2].path}</span
                        >
                    </div>
                    <!-- Terminal content -->
                    <div
                        class="flex-1 font-mono text-[11px] sm:text-xs text-left p-2 leading-relaxed"
                    >
                        <span class="text-gray-400">$</span>
                        <span class="text-white"
                            >{slides[2].gitCommands[0].text}</span
                        ><br />
                        <span class="text-yellow-300">{slides[2].gitCommands[1].commit}</span>
                        <span class="text-white"
                            >{slides[2].gitCommands[1].msg}</span
                        ><br />
                        <span class="text-yellow-300">{slides[2].gitCommands[2].commit}</span>
                        <span class="text-white"
                            >{slides[2].gitCommands[2].msg}</span
                        ><br />
                        <span class="text-yellow-300">{slides[2].gitCommands[3].commit}</span>
                        <span class="text-white"
                            >{slides[2].gitCommands[3].msg}</span
                        ><br />
                        <span class="text-yellow-300">{slides[2].gitCommands[4].commit}</span>
                        <span class="text-white"
                            >{slides[2].gitCommands[4].msg}</span
                        ><br />
                        <span class="text-gray-400">$</span>
                        <span class="text-white animate-pulse">_</span>
                    </div>
                </div>
            </div>

            <!-- Slide Dots Indicators -->
            <div
                class="flex items-center justify-center gap-2 mt-4 relative z-30"
            >
                <button
                    class="slide-dot w-2 h-2 rounded-full bg-blue-500 cursor-pointer"
                    data-index="0"
                    aria-label="Go to slide 1"></button>
                <button
                    class="slide-dot w-2 h-2 rounded-full bg-gray-300 hover:bg-gray-400 cursor-pointer"
                    data-index="1"
                    aria-label="Go to slide 2"></button>
                <button
                    class="slide-dot w-2 h-2 rounded-full bg-gray-300 hover:bg-gray-400 cursor-pointer"
                    data-index="2"
                    aria-label="Go to slide 3"></button>
            </div>
        </div>

        <!-- Right Side: Content Container (First on mobile, second on desktop) -->
        <div
            class="col-span-1 md:col-span-6 order-1 md:order-2 flex flex-col items-center md:items-start text-center md:text-left justify-center"
        >
            <!-- Heading / Name -->
            <h1
                class="landing-title text-gray-900 mb-4 min-h-[1.2em] flex items-center md:justify-start justify-center"
            >
                <span id="typewriter-name" data-text={typedName}
                    >{typedName}</span
                ><span
                    id="name-cursor"
                    class="inline-block text-gray-900 cursor-blink ml-1 select-none"
                    >|</span
                >
            </h1>

            <!-- Subheading / Title -->
            <h2
                class="landing-subtitle text-gray-500 mb-8 min-h-[1.2em] flex items-center md:justify-start justify-center"
            >
                <span
                    id="typewriter-title"
                    data-text={typedTitle}
                    >{typedTitle}</span
                ><span
                    id="title-cursor"
                    class="inline-block text-gray-400 cursor-blink hidden ml-1 select-none"
                    >|</span
                >
            </h2>

            <!-- Description (fades in) -->
            <p
                id="hero-desc"
                class="font-body text-base sm:text-lg text-gray-600 max-w-xl leading-relaxed mb-10 fade-in-element"
            >
                {description}
            </p>

            <!-- CTA Buttons (fades in) -->
            <div
                id="hero-ctas"
                class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto fade-in-element"
            >
                <a
                    href="#projects"
                    class="w-full sm:w-auto bg-[#0F0F10] text-white px-8 py-3.5 rounded-full text-sm font-medium hover:bg-gray-800 transition-all duration-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 text-center cursor-pointer"
                >
                    {ctaProjectsText}
                </a>
                <a
                    href="#contact"
                    class="w-full sm:w-auto bg-white text-gray-750 border border-gray-250 px-8 py-3.5 rounded-full text-sm font-medium hover:bg-gray-50 hover:border-gray-300 hover:text-black transition-all duration-200 hover:-translate-y-0.5 text-center cursor-pointer"
                >
                    {ctaContactText}
                </a>
                <button
                    id="summary-trigger"
                    class="w-full sm:w-auto text-gray-650 hover:text-black text-sm font-medium transition-all duration-200 flex items-center justify-center gap-2 px-5 py-3 rounded-full hover:bg-gray-50 border border-transparent hover:border-gray-200 cursor-pointer group"
                >
                    <svg
                        class="w-4 h-4 text-gray-400 group-hover:text-[#4285F4] transition-colors duration-200"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                        ></path>
                    </svg>
                    <span>{ctaSummaryText}</span>
                </button>
            </div>
        </div>
    </div>
</section>

<!-- Quick Summary Modal Backdrop -->
<div
    id="summary-modal-backdrop"
    class="fixed inset-0 z-50 bg-black/40 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300 ease-out"
>
    <!-- Modal Box -->
    <div
        id="summary-modal-box"
        class="bg-white rounded-xl w-full max-w-3xl mx-4 overflow-hidden border border-gray-200 shadow-2xl scale-95 opacity-0 transition-all duration-300 ease-out flex flex-col max-h-[85vh] relative text-left"
    >
        <!-- Modal Header -->
        <div
            class="px-6 md:px-8 pt-6 pb-4 flex justify-between items-start relative z-10 bg-white border-b border-gray-100"
        >
            <div class="flex-1 pr-4">
                <h3
                    id="summary-job-title"
                    class="font-heading text-xl sm:text-2xl font-medium text-gray-900 leading-tight min-h-[1.25em] opacity-0 transition-opacity duration-300"
                >
                </h3>

                <!-- Google style metadata tags -->
                <div
                    class="flex flex-wrap items-center gap-x-4 gap-y-2 mt-3 text-xs text-gray-500 font-normal"
                >
                    <span
                        class="flex items-center gap-1 opacity-0 transition-opacity duration-300"
                    >
                        <svg
                            class="w-3.5 h-3.5 text-gray-400"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                            ></path>
                        </svg>
                        <span id="summary-tag-candidate" class="min-h-[1.25em]"
                        ></span>
                    </span>
                    <span
                        class="flex items-center gap-1 opacity-0 transition-opacity duration-300"
                    >
                        <svg
                            class="w-3.5 h-3.5 text-gray-400"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            ></path>
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <span id="summary-tag-location" class="min-h-[1.25em]"
                        ></span>
                    </span>
                    <span
                        class="flex items-center gap-1 opacity-0 transition-opacity duration-300"
                    >
                        <svg
                            class="w-3.5 h-3.5 text-gray-400"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z"
                            ></path>
                        </svg>
                        <span id="summary-tag-level" class="min-h-[1.25em]"
                        ></span>
                    </span>
                </div>
            </div>

            <div class="flex items-center gap-1 relative z-20">
                <!-- Close Icon -->
                <button
                    id="summary-modal-close"
                    class="text-gray-400 hover:text-black p-2 hover:bg-gray-100 rounded-full transition-colors cursor-pointer"
                    aria-label="Close modal"
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Modal Body (Scrollable) -->
        <div
            class="p-6 md:p-8 overflow-y-auto space-y-6 text-left relative z-10 bg-white"
        >
            <!-- About the candidate section -->
            <div class="space-y-3">
                <h4
                    id="summary-about-title"
                    class="text-lg sm:text-xl font-medium text-gray-900 tracking-normal min-h-[1.25em] opacity-0 transition-opacity duration-300"
                >
                </h4>
                <p
                    id="summary-about-p1"
                    class="text-sm text-gray-700 leading-relaxed font-normal min-h-[4.5em] opacity-0 transition-opacity duration-300"
                >
                </p>
            </div>

            <hr class="border-gray-200" />

            <!-- Minimum qualifications section -->
            <div class="space-y-3">
                <h4
                    id="summary-min-title"
                    class="text-sm sm:text-base font-bold text-gray-900 tracking-normal min-h-[1.25em] opacity-0 transition-opacity duration-300"
                >
                </h4>
                <ul
                    class="list-disc pl-5 space-y-2 text-sm text-gray-700 font-normal leading-relaxed"
                >
                    <li
                        id="summary-min-q1"
                        class="min-h-[1.25em] opacity-0 transition-opacity duration-300"
                    >
                    </li>
                    <li
                        id="summary-min-q2"
                        class="min-h-[1.25em] opacity-0 transition-opacity duration-300"
                    >
                    </li>
                    <li
                        id="summary-min-q3"
                        class="min-h-[1.25em] opacity-0 transition-opacity duration-300"
                    >
                    </li>
                </ul>
            </div>

            <!-- Preferred qualifications section -->
            <div class="space-y-3 pt-2">
                <h4
                    id="summary-pref-title"
                    class="text-sm sm:text-base font-bold text-gray-900 tracking-normal min-h-[1.25em] opacity-0 transition-opacity duration-300"
                >
                </h4>
                <ul
                    class="list-disc pl-5 space-y-2 text-sm text-gray-700 font-normal leading-relaxed"
                >
                    <li
                        id="summary-pref-q1"
                        class="min-h-[1.25em] opacity-0 transition-opacity duration-300"
                    >
                    </li>
                    <li
                        id="summary-pref-q2"
                        class="min-h-[1.25em] opacity-0 transition-opacity duration-300"
                    >
                    </li>
                    <li
                        id="summary-pref-q3"
                        class="min-h-[1.25em] opacity-0 transition-opacity duration-300"
                    >
                    </li>
                </ul>
            </div>

            <hr class="border-gray-200" />

            <!-- Responsibilities / Key Capabilities section -->
            <div class="space-y-3 pb-4">
                <h4
                    id="summary-resp-title"
                    class="text-lg sm:text-xl font-medium text-gray-900 tracking-normal min-h-[1.25em] opacity-0 transition-opacity duration-300"
                >
                </h4>
                <ul
                    class="list-disc pl-5 space-y-2 text-sm text-gray-700 font-normal leading-relaxed"
                >
                    <li
                        id="summary-resp-r1"
                        class="min-h-[1.25em] opacity-0 transition-opacity duration-300"
                    >
                    </li>
                    <li
                        id="summary-resp-r2"
                        class="min-h-[1.25em] opacity-0 transition-opacity duration-300"
                    >
                    </li>
                    <li
                        id="summary-resp-r3"
                        class="min-h-[1.25em] opacity-0 transition-opacity duration-300"
                    >
                    </li>
                    <li
                        id="summary-resp-r4"
                        class="min-h-[1.25em] opacity-0 transition-opacity duration-300"
                    >
                    </li>
                </ul>
            </div>
        </div>

        <!-- Google style Action Button Area at Bottom -->
        <div
            class="px-6 md:px-8 py-5 flex flex-col sm:flex-row gap-3 border-t border-gray-200 bg-white relative z-10 rounded-b-xl"
        >
            <a
                href={quickSummary.downloadCvUrl}
                target="_blank"
                class="bg-[#e6f4ea] hover:bg-[#ceead6] text-[#0f9d58] px-6 py-2.5 rounded-full text-sm font-semibold transition-all duration-150 cursor-pointer text-center w-full sm:w-auto"
            >
                {quickSummary.downloadCvText}
            </a>
            <a
                href={quickSummary.certificatesUrl}
                class="bg-[#f1f3f4] hover:bg-[#e8eaed] text-[#3c4043] px-6 py-2.5 rounded-full text-sm font-semibold transition-all duration-150 cursor-pointer text-center w-full sm:w-auto"
            >
                {quickSummary.certificatesText}
            </a>
            <a
                href={quickSummary.portfolioUrl}
                id="summary-view-projects-btn"
                class="bg-[#f1f3f4] hover:bg-[#e8eaed] text-[#3c4043] px-6 py-2.5 rounded-full text-sm font-semibold transition-all duration-150 cursor-pointer text-center w-full sm:w-auto"
            >
                {quickSummary.portfolioText}
            </a>
        </div>
    </div>
</div>

<style>
    .landing-title {
        font-family: "Google Sans Flex", "Google Sans", sans-serif;
        font-size: 50px;
        font-weight: 450;
        letter-spacing: var(--landing-main-text-letter-spacing);
        line-height: 56px;
    }
    @media (min-width: 768px) {
        .landing-title {
            font-size: 62px;
            line-height: 84px;
        }
    }
    .landing-subtitle {
        font-family: "Google Sans Flex", "Google Sans", sans-serif;
        font-size: 20px;
        font-weight: 400;
        letter-spacing: -0.2px;
        line-height: 24px;
    }
    @keyframes blink {
        50% {
            opacity: 0;
        }
    }
    .cursor-blink {
        animation: blink 0.8s step-end infinite;
    }
    .fade-in-element {
        opacity: 0;
        transform: translateY(15px);
        transition:
            opacity 1s cubic-bezier(0.16, 1, 0.3, 1),
            transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .fade-in-element.visible {
        opacity: 1;
        transform: translateY(0);
    }

    /* Liquid Glassmorphism Bento Card Styles */
    .liquid-card {
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border: 1px solid rgba(255, 255, 255, 0.65);
        box-shadow:
            0 4px 18px 0 rgba(0, 0, 0, 0.015),
            inset 0 1.5px 1px 0 rgba(255, 255, 255, 0.85);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .liquid-card:hover {
        background: rgba(255, 255, 255, 0.7);
        border-color: rgba(255, 255, 255, 0.9);
        box-shadow:
            0 12px 28px 0 rgba(0, 0, 0, 0.04),
            inset 0 1.5px 1px 0 rgba(255, 255, 255, 0.95);
        transform: translateY(-2px);
    }

    /* Staggered Quick Summary text & grid reveal transitions */
    .summary-reveal {
        opacity: 0;
        transform: translateY(12px);
        transition:
            opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1),
            transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: opacity, transform;
    }
    #summary-modal-box.scale-100.opacity-100 .summary-reveal {
        opacity: 1;
        transform: translateY(0);
    }

    /* Staggered fade scale transition for skill tags */
    .summary-tag {
        opacity: 0;
        transform: scale(0.92);
        transition:
            opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1),
            transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: opacity, transform;
    }
    #summary-modal-box.scale-100.opacity-100 .summary-tag {
        opacity: 1;
        transform: scale(1);
    }
</style>

<script>
    // Particle overlay: small, denser, more visible particles that float over the sentence.
    const canvas = document.getElementById(
        "particle-canvas",
    ) as HTMLCanvasElement | null;
    const ctx = canvas?.getContext("2d") || null;
    const heroSection = document.getElementById("hero-section");

    if (canvas && ctx && heroSection) {
        let containerWidth = 0;
        let containerHeight = 0;
        let mouse = { x: null as number | null, y: null as number | null };

        function resize() {
            if (!heroSection || !canvas || !ctx) return;

            const rect = heroSection.getBoundingClientRect();
            containerWidth = rect.width;
            containerHeight = rect.height;

            const dpr = window.devicePixelRatio || 1;
            canvas.width = Math.round(containerWidth * dpr);
            canvas.height = Math.round(containerHeight * dpr);
            canvas.style.width = containerWidth + "px";
            canvas.style.height = containerHeight + "px";
            ctx.scale(dpr, dpr);
        }

        class Particle {
            x: number;
            y: number;
            vx: number;
            vy: number;
            size: number;
            alpha: number;

            constructor(x: number, y: number) {
                this.x = x;
                this.y = y;
                this.vx = (Math.random() - 0.5) * 0.6;
                this.vy = (Math.random() - 0.5) * 0.6;
                this.size = Math.random() * 1.25 + 0.6; // small particles
                this.alpha = Math.random() * 0.7 + 0.3; // more visible
            }

            update() {
                // simple motion
                this.x += this.vx;
                this.y += this.vy;

                // subtle attraction to mouse (if present)
                if (mouse.x !== null && mouse.y !== null) {
                    const dx = mouse.x - this.x;
                    const dy = mouse.y - this.y;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < 120) {
                        const ang = Math.atan2(dy, dx);
                        // Repel from mouse slightly as in original logic (negative sign)
                        this.vx -= Math.cos(ang) * 0.02;
                        this.vy -= Math.sin(ang) * 0.02;
                    }
                }

                // Limit max velocity to prevent particles from accelerating infinitely
                const speed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
                const maxSpeed = 1.5;
                if (speed > maxSpeed) {
                    this.vx = (this.vx / speed) * maxSpeed;
                    this.vy = (this.vy / speed) * maxSpeed;
                }

                // wrap around edges
                if (this.x < -10) this.x = containerWidth + 10;
                if (this.x > containerWidth + 10) this.x = -10;
                if (this.y < -10) this.y = containerHeight + 10;
                if (this.y > containerHeight + 10) this.y = -10;
            }

            draw() {
                if (!ctx) return;
                ctx.save();
                ctx.fillStyle = `rgba(0,0,0,${this.alpha})`;
                ctx.shadowBlur = 2;
                ctx.shadowColor = "rgba(0,0,0,0.2)";
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            }
        }

        let particles: Particle[] = [];

        function initParticles() {
            particles = [];
            // density: roughly one particle per 6000px^2, constrained
            const area = containerWidth * containerHeight;
            const count = Math.max(120, Math.min(600, Math.floor(area / 6000)));
            for (let i = 0; i < count; i++) {
                particles.push(
                    new Particle(
                        Math.random() * containerWidth,
                        Math.random() * containerHeight,
                    ),
                );
            }
        }

        function connectParticles(maxDist = 90) {
            if (!ctx) return;
            ctx.lineWidth = 0.5;
            for (let i = 0; i < particles.length; i++) {
                for (let j = i + 1; j < particles.length; j++) {
                    const a = particles[i];
                    const b = particles[j];
                    const dx = a.x - b.x;
                    const dy = a.y - b.y;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < maxDist) {
                        const alpha = 0.15 * (1 - dist / maxDist);
                        ctx.strokeStyle = `rgba(100, 100, 100, ${alpha})`;
                        ctx.beginPath();
                        ctx.moveTo(a.x, a.y);
                        ctx.lineTo(b.x, b.y);
                        ctx.stroke();
                    }
                }
            }
        }

        function animate() {
            if (!ctx || !canvas) return;
            ctx.clearRect(0, 0, containerWidth, containerHeight);
            for (let p of particles) {
                p.update();
                p.draw();
            }
            connectParticles(80);
            requestAnimationFrame(animate);
        }

        // Mouse listeners relative to canvas
        heroSection.addEventListener("mousemove", (e) => {
            const rect = canvas.getBoundingClientRect();
            mouse.x = e.clientX - rect.left;
            mouse.y = e.clientY - rect.top;
        });

        heroSection.addEventListener("mouseleave", () => {
            mouse.x = null;
            mouse.y = null;
        });

        // Resize listening
        window.addEventListener("resize", () => {
            resize();
            initParticles();
        });

        // Initialize particles
        resize();
        initParticles();
        animate();
    }

    // Typewriter animation logic
    const nameEl = document.getElementById("typewriter-name");
    const titleEl = document.getElementById("typewriter-title");
    const nameCursor = document.getElementById("name-cursor");
    const titleCursor = document.getElementById("title-cursor");
    const descEl = document.getElementById("hero-desc");
    const ctasEl = document.getElementById("hero-ctas");

    if (nameEl && titleEl) {
        const nameText = nameEl.getAttribute("data-text") || "";
        const titleText = titleEl.getAttribute("data-text") || "";

        // Clear contents for typewriter effect
        nameEl.textContent = "";
        titleEl.textContent = "";

        let nameIndex = 0;
        let titleIndex = 0;

        function typeName() {
            if (nameEl && nameIndex < nameText.length) {
                nameEl.textContent += nameText.charAt(nameIndex);
                nameIndex++;
                setTimeout(typeName, 40);
            } else {
                if (nameCursor) nameCursor.classList.add("hidden");
                if (titleCursor) titleCursor.classList.remove("hidden");
                setTimeout(typeTitle, 150);
            }
        }

        function typeTitle() {
            if (titleEl && titleIndex < titleText.length) {
                titleEl.textContent += titleText.charAt(titleIndex);
                titleIndex++;
                setTimeout(typeTitle, 25);
            } else {
                if (titleCursor) titleCursor.classList.add("hidden");
                setTimeout(() => {
                    if (descEl) descEl.classList.add("visible");
                    setTimeout(() => {
                        if (ctasEl) ctasEl.classList.add("visible");
                    }, 150);
                }, 150);
            }
        }

        // Start typing after a short delay
        setTimeout(typeName, 500);
    }

    // Slide Carousel logic
    const slides = document.querySelectorAll(".slide");
    const dots = document.querySelectorAll(".slide-dot");
    const slideshowWrapper = document.getElementById("slideshow-wrapper");
    let currentSlide = 0;
    let slideInterval: any;
    let isMouseOverSlides = false;

    function showSlide(index: number) {
        slides.forEach((slide, i) => {
            if (i === index) {
                slide.classList.remove("opacity-0");
                slide.classList.add("opacity-100");
            } else {
                slide.classList.remove("opacity-100");
                slide.classList.add("opacity-0");
            }
        });

        dots.forEach((dot, i) => {
            if (i === index) {
                dot.classList.remove("bg-gray-300", "hover:bg-gray-400");
                dot.classList.add("bg-blue-500");
            } else {
                dot.classList.remove("bg-blue-500");
                dot.classList.add("bg-gray-300", "hover:bg-gray-400");
            }
        });

        currentSlide = index;
    }

    function nextSlide() {
        let next = (currentSlide + 1) % slides.length;
        showSlide(next);
    }

    function startSlideShow() {
        if (isMouseOverSlides) return;
        stopSlideShow();
        slideInterval = setInterval(nextSlide, 4000);
    }

    function stopSlideShow() {
        if (slideInterval) clearInterval(slideInterval);
    }

    dots.forEach((dot, index) => {
        dot.addEventListener("click", () => {
            stopSlideShow();
            showSlide(index);
            startSlideShow();
        });
    });

    if (slideshowWrapper) {
        slideshowWrapper.addEventListener("mouseenter", () => {
            isMouseOverSlides = true;
            stopSlideShow();
        });
        slideshowWrapper.addEventListener("mouseleave", () => {
            isMouseOverSlides = false;
            startSlideShow();
        });
    }

    if (slides.length > 0) {
        startSlideShow();
    }

    // --- Quick Summary Modal Logic ---
    const summaryTrigger = document.getElementById("summary-trigger");
    const summaryBackdrop = document.getElementById("summary-modal-backdrop");
    const summaryBox = document.getElementById("summary-modal-box");
    const summaryClose = document.getElementById("summary-modal-close");
    const summaryViewProjects = document.getElementById(
        "summary-view-projects-btn",
    );

    import { heroData } from "../data/heroData";
    const typewriterItems = heroData.typewriterItems;

    let typewriterTimeouts: any[] = [];

    function clearAllTypewriters() {
        typewriterTimeouts.forEach(clearTimeout);
        typewriterTimeouts = [];

        typewriterItems.forEach((item) => {
            const el = document.getElementById(item.id);
            if (el) {
                el.textContent = "";
                el.classList.add("opacity-0");
                if (
                    el.parentElement &&
                    el.parentElement.classList.contains("transition-opacity")
                ) {
                    el.parentElement.classList.add("opacity-0");
                }
            }
        });
    }

    function runAllTypewriters() {
        clearAllTypewriters();

        typewriterItems.forEach((item) => {
            const el = document.getElementById(item.id);
            if (!el) return;
            const element = el;

            const startTimeout = setTimeout(() => {
                // Remove opacity-0 transition classes to fade in
                element.classList.remove("opacity-0");
                if (
                    element.parentElement &&
                    element.parentElement.classList.contains(
                        "transition-opacity",
                    )
                ) {
                    element.parentElement.classList.remove("opacity-0");
                }

                let i = 0;
                const chunkSize = 3;

                function type() {
                    if (i < item.text.length) {
                        element.textContent += item.text.slice(
                            i,
                            i + chunkSize,
                        );
                        i += chunkSize;
                        typewriterTimeouts.push(setTimeout(type, 10));
                    }
                }
                type();
            }, item.delay);

            typewriterTimeouts.push(startTimeout);
        });
    }

    function openSummary() {
        if (summaryBackdrop && summaryBox) {
            summaryBackdrop.classList.remove(
                "opacity-0",
                "pointer-events-none",
            );
            summaryBackdrop.classList.add("opacity-100");
            summaryBox.classList.remove("scale-95", "opacity-0");
            summaryBox.classList.add("scale-100", "opacity-100");
            document.body.style.overflow = "hidden";
            // Wait slightly for the modal scale transition to finish, then start fast staggered typing
            setTimeout(runAllTypewriters, 250);
        }
    }

    function closeSummary() {
        if (summaryBackdrop && summaryBox) {
            summaryBackdrop.classList.remove("opacity-100");
            summaryBackdrop.classList.add("opacity-0", "pointer-events-none");
            summaryBox.classList.remove("scale-100", "opacity-100");
            summaryBox.classList.add("scale-95", "opacity-0");
            document.body.style.overflow = "";
            clearAllTypewriters();
        }
    }

    if (summaryTrigger) {
        summaryTrigger.addEventListener("click", openSummary);
    }
    if (summaryClose) {
        summaryClose.addEventListener("click", closeSummary);
    }
    if (summaryBackdrop) {
        summaryBackdrop.addEventListener("click", (e) => {
            if (e.target === summaryBackdrop) closeSummary();
        });
    }
    if (summaryViewProjects) {
        summaryViewProjects.addEventListener("click", closeSummary);
    }
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeSummary();
    });
</script>
