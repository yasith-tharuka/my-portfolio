</style>

<script>
  // Simulated Interactive CV Download progress bar animation
  const downloadBtn = document.getElementById("cv-download-btn");
  const progressBar = document.getElementById("cv-progress-bar");
  const btnText = document.getElementById("cv-btn-text");

  if (downloadBtn && progressBar && btnText) {
    let isDownloading = false;

    downloadBtn.addEventListener("click", () => {
      if (isDownloading) return;
      isDownloading = true;

      // Disable pointer events during download
      downloadBtn.style.pointerEvents = "none";
      progressBar.style.width = "0%";
      progressBar.style.backgroundColor = "rgba(16, 185, 129, 0.25)"; // green tint

      let progress = 0;
      const interval = setInterval(() => {
        progress += Math.floor(Math.random() * 12) + 5; // increment progress randomly
        if (progress >= 100) {
          progress = 100;
          progressBar.style.width = "100%";
          btnText.textContent = "Complete!";
          clearInterval(interval);

          // Trigger actual file download download after short delay
          setTimeout(() => {
            const tempLink = document.createElement("a");
            tempLink.href = "/Yasith_Tharuka_CV.pdf";
            tempLink.download = "Yasith_Tharuka_CV.pdf";
            tempLink.target = "_blank";
            document.body.appendChild(tempLink);
            tempLink.click();
            document.body.removeChild(tempLink);

            // Reset button state
            setTimeout(() => {
              progressBar.style.width = "0%";
              btnText.textContent = "Download CV";
              downloadBtn.style.pointerEvents = "auto";
              isDownloading = false;
            }, 1500);
          }, 400); // Wait 400ms before starting download
        } else {
          progressBar.style.width = `${progress}%`;
          btnText.textContent = `Downloading (${progress}%)...`;
        }
      }, 120); // ticks every 120ms
    });
  }
</script>
