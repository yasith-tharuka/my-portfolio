        <!-- Mobile Menu Overlay Panel -->
        <div
            id="mobile-menu-overlay"
            class="fixed top-14.25 left-0 right-0 bottom-0 bg-white z-45 md:hidden hidden flex-col overflow-y-auto px-6 py-4 transition-all duration-300 opacity-0 translate-y-4"
