---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="w-full bg-white border-t border-gray-250 pt-20 pb-12 relative overflow-hidden font-body">
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16 pb-14">
      <!-- Left column: Clean header -->
      <div class="col-span-12 md:col-span-6 flex flex-col justify-between">
        <div class="max-w-md">
          <h2 class="font-heading text-3xl sm:text-4xl font-normal text-gray-900 leading-tight mb-5 tracking-tight reveal-item" style="animation-delay: 50ms;">
            Let's connect & <br class="hidden sm:inline" />build the future.
          </h2>
          <p class="text-sm text-gray-650 leading-relaxed font-light reveal-item" style="animation-delay: 100ms;">
            Open for research collaborations, open-source projects, and professional full-stack development opportunities.
          </p>
        </div>
      </div>

      <!-- Right column: Link groupings -->
      <div class="col-span-12 md:col-span-6 grid grid-cols-2 gap-8">
        <!-- Connect / Social Links Column -->
        <div>
          <span class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4 reveal-item" style="animation-delay: 100ms;">Connect</span>
          <ul class="space-y-3.5 text-sm font-medium">
            <li class="reveal-item" style="animation-delay: 150ms;">
              <a
                href="https://www.linkedin.com/in/yasith-tharuka/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-650 hover:text-blue-600 transition-colors inline-flex items-center gap-1 group"
              >
                LinkedIn
                <svg class="w-3 h-3 text-gray-400 group-hover:text-blue-600 transition-transform duration-250 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </li>
            <li class="reveal-item" style="animation-delay: 200ms;">
              <a
                href="https://github.com/yasith-tharuka"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-650 hover:text-black transition-colors inline-flex items-center gap-1 group"
              >
                GitHub
                <svg class="w-3 h-3 text-gray-400 group-hover:text-black transition-transform duration-250 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </li>
            <li class="reveal-item" style="animation-delay: 250ms;">
              <a
                href="https://scholar.google.com/citations?user=Sm5u3UAAAAAJ"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-650 hover:text-emerald-600 transition-colors inline-flex items-center gap-1 group"
              >
                Google Scholar
                <svg class="w-3 h-3 text-gray-400 group-hover:text-emerald-600 transition-transform duration-250 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </li>
            <li class="reveal-item" style="animation-delay: 300ms;">
              <a
                href="https://medium.com/@yasiththaruka"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-650 hover:text-black transition-colors inline-flex items-center gap-1 group"
              >
                Medium
                <svg class="w-3 h-3 text-gray-400 group-hover:text-black transition-transform duration-250 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </li>
            <li class="reveal-item" style="animation-delay: 350ms;">
              <a
                href="https://www.researchgate.net/profile/Yasith-Tharuka-2"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-650 hover:text-blue-500 transition-colors inline-flex items-center gap-1 group"
              >
                ResearchGate
                <svg class="w-3 h-3 text-gray-400 group-hover:text-blue-500 transition-transform duration-250 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </li>
            <li class="reveal-item" style="animation-delay: 400ms;">
              <a
                href="https://orcid.org/0009-0007-7095-3201"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-650 hover:text-lime-600 transition-colors inline-flex items-center gap-1 group"
              >
                ORCID
                <svg class="w-3 h-3 text-gray-400 group-hover:text-lime-600 transition-transform duration-250 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </li>
          </ul>
        </div>

        <!-- Navigation links -->
        <div>
          <span class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4 reveal-item" style="animation-delay: 150ms;">Explore</span>
          <ul class="space-y-3.5 text-sm font-medium">
            <li class="reveal-item" style="animation-delay: 200ms;">
              <a href="/" class="text-gray-650 hover:text-black transition-colors">Home</a>
            </li>
            <li class="reveal-item" style="animation-delay: 250ms;">
              <a href="/#projects" class="text-gray-650 hover:text-black transition-colors">Projects</a>
            </li>
            <li class="reveal-item" style="animation-delay: 300ms;">
              <a href="/certifications" class="text-gray-650 hover:text-black transition-colors">Certifications</a>
            </li>
            <li class="reveal-item" style="animation-delay: 350ms;">
              <a href="/#contact" class="text-gray-650 hover:text-black transition-colors">Contact</a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Backdrop huge typography watermark, inspired by the Google Antigravity footer -->
    <div class="relative w-full overflow-hidden select-none pointer-events-none mt-2 -mb-4 sm:-mb-6 reveal-item" style="animation-delay: 450ms;">
      <span class="block font-heading text-[12vw] font-bold text-gray-100 tracking-tighter leading-none select-none">
        Yasith Tharuka
      </span>
    </div>

    <!-- Bottom copyright row -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-gray-500 font-normal relative z-10 pt-12 reveal-item" style="animation-delay: 500ms;">
      <div class="flex items-center gap-1 font-heading font-medium text-sm text-gray-900 tracking-tight">
        <span class="font-semibold text-gray-900">Yasith</span>
        <span class="font-medium text-gray-600 ml-0.5">Tharuka</span>
      </div>
      <div>
        <span>&copy; {currentYear} Yasith Tharuka. All rights reserved.</span>
      </div>
    </div>
  </div>
</footer>

<style>
  @keyframes revealUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .reveal-item {
    opacity: 0;
    transform: translateY(16px);
    will-change: transform, opacity;
  }

  .reveal-item.animate {
    animation: revealUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>

<script>
  function initFooterObserver() {
    const footer = document.querySelector("footer");
    if (!footer) return;

    const revealItems = footer.querySelectorAll(".reveal-item");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            revealItems.forEach((item) => {
              item.classList.add("animate");
            });
            // Stop observing once animated to keep it smooth
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.05, // Trigger as soon as 5% of footer enters the screen
        rootMargin: "0px 0px -20px 0px"
      }
    );

    observer.observe(footer);
  }

  // Run on initial load
  document.addEventListener("DOMContentLoaded", initFooterObserver);
  
  // Support Astro View Transitions page loads if integrated later
  document.addEventListener("astro:page-load", initFooterObserver);
</script>
