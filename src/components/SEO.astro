---
interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
}

const {
  title,
  description,
  image = '/images/og-image.png', // Fallback OG image if you create one later
  article = false,
} = Astro.props;

// Use Astro.url to get the full, absolute URL of the current page
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
// Resolve image URL against the site base to get an absolute URL
const resolvedImageWithDomain = new URL(image, Astro.site).toString();

// Construct JSON-LD Structured Data for Google
const schema = article ? {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL.toString()
  },
  "headline": title,
  "description": description,
  "image": resolvedImageWithDomain,
  "author": {
    "@type": "Person",
    "name": "Yasith Tharuka",
    "url": Astro.site?.toString()
  }
} : {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Yasith Tharuka",
  "url": Astro.site?.toString(),
  "jobTitle": "Software Developer",
  "description": description
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#0a0a0a" />
<link rel="apple-touch-icon" href="/favicon.svg" />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedImageWithDomain} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={resolvedImageWithDomain} />
