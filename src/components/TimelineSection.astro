        </div>
      )}
    </div>
  </section>

  <!-- Interactive Category Filter Tabs (Only on full timeline page) -->
  {!isHomePage && (
    <section class="max-w-7xl mx-auto px-6 mb-16 relative z-20">
      <div class="flex flex-wrap gap-2.5 md:gap-3.5" id="filter-tabs-container">
        {categories.map((cat, idx) => (
          <button
            data-filter={cat.id}
            class={`filter-tab px-5 py-2.5 rounded-full text-xs sm:text-sm font-medium border transition-all duration-300 cursor-pointer font-san ${
              idx === 0
                ? "bg-white/40 text-black border-white/50 shadow-sm backdrop-blur-md active-all"
                : "bg-white/10 text-gray-700 border-white/20 hover:bg-white/30 hover:border-white/40 hover:text-black shadow-sm backdrop-blur-md"
            }`}
            id={`tab-btn-${cat.id}`}
          >
            {cat.name}
          </button>
        ))}
      </div>
    </section>
  )}

  <!-- Timeline Tree Section -->
  <section class="max-w-7xl mx-auto px-4 relative z-20">
    <div class="relative py-12 w-full" id="timeline-tree-wrapper">
      
      <!-- Dynamic SVG Spine Canvas -->
      <svg id="timeline-svg" class="absolute inset-0 w-full h-full pointer-events-none z-10 overflow-visible">
        <!-- Glow path -->
        <path id="timeline-path-glow" fill="none" stroke="url(#spine-gradient)" stroke-width="8" stroke-linecap="round" stroke-linejoin="round" class="opacity-30 blur-md transition-all duration-300" />
        <!-- Core path -->
        <path id="timeline-path-core" fill="none" stroke="url(#spine-gradient)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" class="transition-all duration-300" />
        
