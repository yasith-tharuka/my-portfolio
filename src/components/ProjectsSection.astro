---
// src/components/ProjectsSection.astro
import { projectsData } from "../data/projectsData";

interface Props {
  limit?: number;
  showFilters?: boolean;
  showViewMore?: boolean;
}

const { 
  limit, 
  showFilters = true, 
  showViewMore = false 
} = Astro.props;

const { 
  accent, 
  heroTitle, 
  heroDescription, 
  categories, 
  projects 
} = projectsData;

const displayedProjects = limit ? projects.slice(0, limit) : projects;
---

<div class="w-full relative font-body bg-[#FAFAFC] py-16">
  <!-- Interactive Background "Water Bubble Magic" droplets for liquid refraction -->
  <div class="absolute top-10 left-5 w-64 h-64 rounded-full bg-blue-400/12 blur-3xl animate-float-bubble-1 pointer-events-none"></div>
  <div class="absolute bottom-10 right-5 w-72 h-72 rounded-full bg-emerald-400/10 blur-3xl animate-float-bubble-2 pointer-events-none"></div>
  <div class="absolute top-1/3 left-1/4 w-48 h-48 rounded-full bg-purple-400/8 blur-3xl animate-float-bubble-3 pointer-events-none"></div>
  <div class="absolute bottom-1/3 right-1/4 w-52 h-52 rounded-full bg-amber-400/6 blur-3xl animate-float-bubble-1 pointer-events-none"></div>

  <!-- Hero / Header Section -->
  <section class="max-w-6xl mx-auto px-6 mb-14 relative z-20">
    <div class="flex flex-col md:flex-row md:items-start justify-between gap-8 pb-10 border-b border-gray-200/50">
      <div class="max-w-3xl">
        <span class="text-xs font-semibold text-[#10B981] uppercase tracking-widest block mb-2 font-san">{accent}</span>
        <h1 class="font-san text-4xl sm:text-5xl font-normal text-gray-900 tracking-tight leading-[1.1] mb-4" set:html={heroTitle}></h1>
        <p class="text-base sm:text-lg text-gray-550 leading-relaxed font-light mt-3">
          {heroDescription}
        </p>
      </div>

      <!-- Back to Home (Only shown on dedicated projects page) -->
      {showFilters && (
        <div class="flex-shrink-0 mt-4 md:mt-2">
          <a
            href="/"
            class="inline-flex items-center gap-2 bg-white/40 hover:bg-white/60 text-gray-900 hover:text-black px-6 py-2.5 rounded-full text-xs sm:text-sm font-medium transition-all duration-250 hover:-translate-y-0.5 font-san border border-white/60 hover:border-white/80 shadow-sm backdrop-blur-md"
            id="back-home-button"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
               <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Return Home
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- Interactive Category Filter Tabs (Only shown on full list) -->
  {showFilters && (
    <section class="max-w-6xl mx-auto px-6 mb-12 relative z-20">
      <div class="flex flex-wrap gap-2.5 md:gap-3" id="filter-tabs-container">
        {categories.map((cat, idx) => (
          <button
            data-filter={cat.id}
            class={`filter-tab px-5 py-2.5 rounded-full text-xs sm:text-sm font-medium border transition-all duration-300 cursor-pointer font-san ${
              idx === 0
                ? "bg-gray-900 text-white border-gray-900 shadow-sm active-all"
                : "bg-white/40 text-gray-700 border-white/60 hover:bg-white/75 hover:border-white/80 hover:text-black shadow-sm backdrop-blur-md"
            }`}
            id={`tab-btn-${cat.id}`}
          >
            {cat.name}
          </button>
        ))}
      </div>
    </section>
  )}

  <!-- Projects Grid -->
  <section class="max-w-6xl mx-auto px-6 relative z-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 transition-all duration-300" id="projects-grid">
      {displayedProjects.map((project, idx) => (
        <div
          data-category={project.category}
          data-index={idx}
          class="liquid-glass-card group relative p-6 sm:p-8 flex flex-col justify-between"
          id={`project-card-${project.id}`}
        >
          <!-- Accent bubble glow overlay that animates on card hover -->
          <div 
            class="absolute -top-10 -left-10 w-28 h-28 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-2xl pointer-events-none"
            style={`background-color: ${project.accentColor}20`}
          ></div>

          <div>
            <!-- Project Interactive Visual Header -->
            <div class="w-full h-44 rounded-2xl bg-white/40 border border-white/60 shadow-[inset_0_1px_2px_rgba(255,255,255,0.7)] relative overflow-hidden mb-6 flex items-center justify-center backdrop-blur-sm group-hover:border-white/80 transition-colors">
              <!-- Visual Content (Dynamic SVGs) -->
              {project.category === 'ai-ml' && (
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-full h-full max-h-[120px] text-[#4285F4] opacity-80" viewBox="0 0 200 100" fill="none">
                    <g class="animate-pulse-slow">
                      <circle cx="50" cy="50" r="8" fill="#4285F4" fill-opacity="0.2" stroke="#4285F4" stroke-width="1.5"/>
                      <circle cx="100" cy="25" r="8" fill="#4285F4" fill-opacity="0.2" stroke="#4285F4" stroke-width="1.5"/>
                      <circle cx="100" cy="75" r="8" fill="#4285F4" fill-opacity="0.2" stroke="#4285F4" stroke-width="1.5"/>
                      <circle cx="150" cy="50" r="8" fill="#4285F4" fill-opacity="0.2" stroke="#4285F4" stroke-width="1.5"/>
                      
                      <path d="M58 50H92 M108 25H142 M108 75H142 M57 44 L93 28 M57 56 L93 72 M143 44 L107 28 M143 56 L107 72" stroke="#4285F4" stroke-width="1" stroke-dasharray="4 3" class="animate-dash-flow"/>
                    </g>
                    {project.id === 'aetheria-ai' ? (
                      <rect x="75" y="38" width="50" height="24" rx="4" fill="none" stroke="#EA4335" stroke-width="1.5" class="animate-scanner"/>
                    ) : (
                      <circle cx="100" cy="50" r="16" fill="none" stroke="#FBBC05" stroke-width="1.5" stroke-dasharray="3 3"/>
                    )}
                  </svg>
                </div>
              )}

              {project.category === 'cloud-devops' && (
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-full h-full max-h-[120px] text-[#8B5CF6] opacity-80" viewBox="0 0 200 100" fill="none">
                    <g class="animate-float-cloud">
                      <path d="M70 65a15 15 0 010-30 20 20 0 0137-10 15 15 0 0123 15 15 15 0 010 25z" fill="none" stroke="#8B5CF6" stroke-width="1.8"/>
                      <circle cx="100" cy="50" r="6" fill="#8B5CF6"/>
                      <path d="M100 56v14M85 50h-15M115 50h15" stroke="#8B5CF6" stroke-width="1.5" stroke-linecap="round"/>
                      <circle cx="70" cy="50" r="3" fill="#34A853" class="animate-ping-slow"/>
                      <circle cx="130" cy="50" r="3" fill="#FBBC05" class="animate-ping-slow"/>
                    </g>
                  </svg>
                </div>
              )}

              {project.category === 'distributed-systems' && (
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-full h-full max-h-[120px] text-[#34A853] opacity-80" viewBox="0 0 200 100" fill="none">
                    <g>
                      <rect x="85" y="15" width="30" height="15" rx="3" fill="none" stroke="#34A853" stroke-width="1.8" class="animate-pulse-slow"/>
                      <rect x="50" y="55" width="30" height="15" rx="3" fill="none" stroke="#34A853" stroke-width="1.5"/>
                      <rect x="120" y="55" width="30" height="15" rx="3" fill="none" stroke="#34A853" stroke-width="1.5"/>
                      
                      <path d="M100 30v15M100 45H65v10M100 45h55v10" stroke="#34A853" stroke-width="1.5" stroke-linecap="round"/>
                      <circle cx="100" cy="45" r="3" fill="#34A853" class="animate-pulse-node"/>
                    </g>
                  </svg>
                </div>
              )}

              {project.category === 'fullstack' && (
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-full h-full max-h-[120px] text-[#EA4335] opacity-80" viewBox="0 0 200 100" fill="none">
                    <g>
                      <rect x="40" y="20" width="120" height="60" rx="6" fill="none" stroke="#EA4335" stroke-width="1.8"/>
                      <path d="M40 65h120M60 80h80" stroke="#EA4335" stroke-width="1.5"/>
                      <circle cx="50" cy="72.5" r="2" fill="#34A853"/>
                      <circle cx="58" cy="72.5" r="2" fill="#FBBC05"/>
                      
                      {/* Telemetry wave */}
                      <path d="M50 45 q15-20 30 0 t30 0 t30-15 t30 15" fill="none" stroke="#EA4335" stroke-width="1.5" stroke-linecap="round" class="animate-wave"/>
                    </g>
                  </svg>
                </div>
              )}
              
              <!-- Hover dynamic glare overlay -->
              <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/15 to-white/30 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none z-10"></div>
            </div>

            <!-- Date & Category badge -->
            <div class="flex items-center justify-between gap-4 mb-4">
              <span class="px-3 py-1 text-[10px] font-semibold uppercase tracking-wider rounded-full bg-white/50 border border-white/60 text-gray-500 backdrop-blur-sm shadow-[0_1px_2px_rgba(0,0,0,0.01)]">
                {project.date}
              </span>
              
              <span class="text-[10px] font-bold uppercase tracking-widest text-gray-400">
                {project.category === 'ai-ml' && "AI & DEEP LEARNING"}
                {project.category === 'cloud-devops' && "CLOUD & DEVOPS"}
                {project.category === 'distributed-systems' && "DISTRIBUTED SYSTEMS"}
                {project.category === 'fullstack' && "FULL-STACK WEB"}
              </span>
            </div>

            <!-- Title -->
            <h3 class="font-san text-xl sm:text-2xl font-medium tracking-normal text-gray-900 leading-snug group-hover:text-[#10B981] transition-colors mb-2">
              {project.title}
            </h3>

            <!-- Subtitle -->
            <p class="text-xs font-semibold text-gray-500 mt-1 font-sans uppercase tracking-wider">
              {project.subtitle}
            </p>

            <!-- Short Description -->
            <p class="text-sm text-gray-550 leading-relaxed mt-3.5 font-light">
              {project.description}
            </p>

            <!-- Skills pills -->
            <div class="mt-5 flex flex-wrap gap-1.5">
              {project.skills.slice(0, 4).map((skill) => (
                <span 
                  class="px-2.5 py-1 rounded-lg text-[10px] font-medium bg-white/50 border border-white/70 text-gray-650 shadow-[0_1px_2px_rgba(0,0,0,0.01)] select-none hover:border-gray-300 transition-colors"
                  style={`--hover-accent: ${project.accentColor}`}
                >
                  {skill}
                </span>
              ))}
              {project.skills.length > 4 && (
                <span class="px-2.5 py-1 rounded-lg text-[10px] font-medium bg-gray-100/50 border border-gray-200/40 text-gray-400">
                  +{project.skills.length - 4} more
                </span>
              )}
            </div>
          </div>

          <!-- Bottom Action Buttons -->
          <div class="mt-6 border-t border-gray-200/40 pt-4 flex items-center justify-between">
            <!-- Details Trigger Link -->
            <button 
              class="project-details-trigger text-xs font-semibold text-[#10B981] hover:text-[#059669] flex items-center gap-1 cursor-pointer transition-colors group/link"
              data-project-id={project.id}
              id={`details-btn-${project.id}`}
            >
              View Case Study
              <svg class="w-3.5 h-3.5 transform group-hover/link:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </button>

            <!-- External Code Link -->
            <a 
              href={project.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="w-8 h-8 rounded-full bg-white/50 border border-white/60 hover:bg-white/80 hover:border-white/80 flex items-center justify-center text-gray-600 hover:text-black transition-colors shadow-sm"
              title="View Repository"
            >
              <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.11.82-.26.82-.577v-2.234c-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22v3.293c0 .319.22.694.825.576C20.565 21.795 24 17.3 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- View More Innovations Nav Button (Only shown if showViewMore is active) -->
  {showViewMore && (
    <div class="mt-12 text-center relative z-20 font-san">
      <a
        href="/projects"
        class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 text-gray-700 hover:text-gray-900 px-8 py-3.5 rounded-full text-sm font-medium border border-gray-200 transition-all duration-300 hover:shadow-md hover:-translate-y-0.5 active:scale-98 shadow-sm group no-underline hover:no-underline"
        id="view-all-projects-btn"
      >
        Explore All Innovations ({projects.length})
        <svg class="w-4 h-4 text-gray-400 group-hover:text-black group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  )}

  <!-- Detailed Modal Panel Overlay (Horizontal Split Grid Design) -->
  <div
    id="project-modal-backdrop"
    class="fixed inset-0 bg-black/75 backdrop-blur-md z-50 flex items-center justify-center p-4 md:p-6 opacity-0 pointer-events-none transition-all duration-300"
  >
    <!-- Modal Box: Details left, Visuals & stats right -->
    <div
      id="project-modal-box"
      class="relative w-full max-w-5xl bg-white/90 backdrop-blur-2xl rounded-3xl overflow-hidden shadow-2xl transform scale-95 opacity-0 transition-all duration-300 grid grid-cols-1 md:grid-cols-12 min-h-[500px] md:h-[82vh] border border-white/40"
    >
      <!-- Close button inside the modal box -->
      <button
        id="project-modal-close"
        class="absolute top-5 right-5 z-20 w-10 h-10 bg-white/20 hover:bg-white/40 text-gray-850 rounded-full flex items-center justify-center transition-colors cursor-pointer border border-white/45 backdrop-blur-sm"
        aria-label="Close panel"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Left Column: Details (7 cols out of 12) -->
      <div class="col-span-12 md:col-span-7 p-6 sm:p-8 md:p-10 flex flex-col justify-between overflow-y-auto h-full relative z-10">
        <div>
          <!-- Header with Accent block -->
          <div class="flex items-center gap-3 mb-4">
            <span id="modal-project-date" class="px-3 py-1 text-[10px] font-semibold uppercase tracking-wider rounded-full bg-white/50 border border-white/70 text-gray-550 shadow-sm">
              <!-- Dynamically populated -->
            </span>
            <span id="modal-project-badge" class="text-xs font-semibold text-[#10B981] uppercase tracking-widest">
              <!-- Dynamically populated -->
            </span>
          </div>

          <!-- Title -->
          <h2 id="modal-project-title" class="font-san text-2xl sm:text-3xl font-medium text-gray-900 leading-tight mb-2">
            <!-- Dynamically populated -->
          </h2>

          <!-- Subtitle -->
          <p id="modal-project-subtitle" class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-6">
            <!-- Dynamically populated -->
          </p>

          <!-- Core stats pill summary in mobile view -->
          <div id="modal-mobile-meta" class="flex flex-wrap gap-2.5 mb-6 text-xs text-gray-600 border-t border-b border-gray-100 py-3 font-sans">
            <div><strong>Role:</strong> <span id="modal-meta-role"></span></div>
            <div class="text-gray-300">•</div>
            <div><strong>Client/Scope:</strong> <span id="modal-meta-client"></span></div>
          </div>

          <!-- Description Section -->
          <div class="mb-6">
            <h4 class="text-xs font-semibold text-gray-450 uppercase tracking-wider mb-2">Detailed Case Study</h4>
            <p id="modal-project-desc" class="text-sm text-gray-650 leading-relaxed font-light">
              <!-- Dynamically populated -->
            </p>
          </div>

          <!-- Features Bullet List -->
          <div class="mb-6">
            <h4 class="text-xs font-semibold text-gray-450 uppercase tracking-wider mb-3">Key Capabilities</h4>
            <ul id="modal-project-features" class="space-y-2.5 text-xs text-gray-600 font-light">
              <!-- Dynamically populated -->
            </ul>
          </div>

          <!-- Challenges & Solutions Box -->
          <div class="mb-6 bg-gradient-to-br from-white/30 to-white/10 border border-white/50 p-4 sm:p-5 rounded-2xl shadow-sm backdrop-blur-sm">
            <h4 class="text-xs font-semibold text-gray-700 uppercase tracking-wider mb-3 flex items-center gap-1.5">
              <svg class="w-4 h-4 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
              Engineering Challenge & Solution
            </h4>
            <div class="space-y-2.5 text-xs leading-relaxed">
              <p class="text-gray-700"><strong class="text-gray-900 font-semibold block mb-0.5">The Challenge:</strong> <span id="modal-challenge-prob"></span></p>
              <p class="text-gray-700 border-t border-white/40 pt-2.5 mt-2.5"><strong class="text-gray-900 font-semibold block mb-0.5">The Resolution:</strong> <span id="modal-challenge-sol"></span></p>
            </div>
          </div>

          <!-- Full Tech Stack Tags -->
          <div class="mb-6">
            <h4 class="text-xs font-semibold text-gray-450 uppercase tracking-wider mb-3">Complete Stack & Tools</h4>
            <div id="modal-project-skills" class="flex flex-wrap gap-1.5">
              <!-- Dynamically populated -->
            </div>
          </div>
        </div>

        <!-- Footer Actions -->
        <div class="pt-6 border-t border-gray-200/40 flex flex-wrap items-center justify-between gap-4 mt-8">
          <a
            id="modal-github-btn"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-white/40 hover:bg-white/60 text-gray-900 hover:text-black border border-white/60 px-5 py-2.5 rounded-full text-xs font-semibold transition-all duration-200 shadow-sm backdrop-blur-md"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.11.82-.26.82-.577v-2.234c-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22v3.293c0 .319.22.694.825.576C20.565 21.795 24 17.3 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            Source Code
          </a>

          <a
            id="modal-live-btn"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-gray-900 hover:bg-gray-800 text-white px-6 py-2.5 rounded-full text-xs font-semibold transition-all duration-200 shadow-md"
          >
            Launch Live Demo
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Right Column: Interactive Diagram & metrics (5 cols out of 12) -->
      <div id="modal-diagram-column" class="col-span-12 md:col-span-5 bg-gradient-to-b from-white/60 to-white/20 backdrop-blur-md border-t md:border-t-0 md:border-l border-gray-200/50 p-6 sm:p-8 flex flex-col justify-between overflow-y-auto h-full">
        <!-- Visual Architecture Container -->
        <div>
          <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">System Architecture</h4>
          <div id="modal-architecture-container" class="relative w-full aspect-[4/3] rounded-2xl border border-white/60 bg-white/40 shadow-[inset_0_1px_2px_rgba(255,255,255,0.7)] p-4 flex flex-col justify-between gap-3 overflow-hidden backdrop-blur-sm shadow-sm mb-6">
            <!-- Node blocks dynamically injected here -->
          </div>
        </div>

        <!-- Metrics Grid -->
        <div>
          <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Target Performance Metrics</h4>
          <div id="modal-project-metrics" class="grid grid-cols-3 gap-3">
            <!-- Dynamic stats elements injected here -->
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Floating bubbles keyframe animations */
  @keyframes float-bubble-1 {
    0% { transform: translateY(0px) translateX(0px) scale(1); }
    50% { transform: translateY(-40px) translateX(20px) scale(1.1); }
    100% { transform: translateY(0px) translateX(0px) scale(1); }
  }
  @keyframes float-bubble-2 {
    0% { transform: translateY(0px) translateX(0px) scale(1.05); }
    50% { transform: translateY(-30px) translateX(-25px) scale(0.95); }
    100% { transform: translateY(0px) translateX(0px) scale(1.05); }
  }
  @keyframes float-bubble-3 {
    0% { transform: translateY(0px) translateX(0px) rotate(0deg); }
    50% { transform: translateY(-20px) translateX(15px) rotate(180deg); }
    100% { transform: translateY(0px) translateX(0px) rotate(360deg); }
  }
  .animate-float-bubble-1 { animation: float-bubble-1 14s ease-in-out infinite; }
  .animate-float-bubble-2 { animation: float-bubble-2 16s ease-in-out infinite; }
  .animate-float-bubble-3 { animation: float-bubble-3 18s ease-in-out infinite; }

  /* Interactive graphics keyframe effects */
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.02); }
  }
  @keyframes dash-flow {
    to { stroke-dashoffset: -20; }
  }
  @keyframes scan {
    0%, 100% { transform: translateY(-5px); }
    50% { transform: translateY(5px); }
  }
  @keyframes float-cloud {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-4px); }
  }
  @keyframes ping-slow {
    0% { transform: scale(1); opacity: 1; }
    70%, 100% { transform: scale(2.2); opacity: 0; }
  }
  @keyframes wave {
    0% { transform: translateX(0); }
    100% { transform: translateX(-15px); }
  }
  .animate-pulse-slow { animation: pulse-slow 4s ease-in-out infinite; transform-origin: center; }
  .animate-dash-flow { stroke-dasharray: 6; animation: dash-flow 1.5s linear infinite; }
  .animate-scanner { animation: scan 3s ease-in-out infinite; }
  .animate-float-cloud { animation: float-cloud 4s ease-in-out infinite; }
  .animate-ping-slow { animation: ping-slow 2s cubic-bezier(0, 0, 0.2, 1) infinite; transform-origin: center; }
  .animate-wave { animation: wave 2.5s linear infinite; }

  /* Premium Apple Liquid Glass Card */
  .liquid-glass-card {
    position: relative;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.45) 0%, rgba(255, 255, 255, 0.1) 100%);
    backdrop-filter: blur(24px) saturate(190%);
    -webkit-backdrop-filter: blur(24px) saturate(190%);
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 
      inset 0 1.5px 0 rgba(255, 255, 255, 0.75), 
      inset 0 -1.5px 0 rgba(0, 0, 0, 0.05),
      0 10px 30px -10px rgba(0, 0, 0, 0.04),
      0 1px 3px rgba(0, 0, 0, 0.02);
    border-radius: 2.2rem;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
  }

  .liquid-glass-card:hover {
    transform: translateY(-6px) scale(1.015);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0.15) 100%);
    border-color: rgba(255, 255, 255, 0.65);
    box-shadow: 
      inset 0 2px 0 rgba(255, 255, 255, 0.85), 
      inset 0 -1px 0 rgba(0, 0, 0, 0.05),
      0 22px 40px -15px rgba(0, 0, 0, 0.1),
      0 2px 8px rgba(0, 0, 0, 0.04);
  }

  /* Liquid reflection gloss curvature across the top */
  .liquid-glass-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 45%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.35) 0%, rgba(255, 255, 255, 0) 100%);
    border-radius: 2.2rem 2.2rem 50% 50% / 2.2rem 2.2rem 20% 20%;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  /* Filter-out transition classes */
  .project-card-filtered-out {
    opacity: 0;
    transform: scale(0.95) translateY(15px);
    pointer-events: none;
    position: absolute;
    width: 0;
    height: 0;
    padding: 0;
    margin: 0;
    border: none;
    overflow: hidden;
  }

  /* Skill pill hover color styling */
  span[style*="--hover-accent"] {
    transition: all 0.25s ease;
  }
  span[style*="--hover-accent"]:hover {
    border-color: var(--hover-accent);
    color: #111111;
    transform: translateY(-1.5px);
    box-shadow: 0 4px 12px var(--hover-accent)15;
  }
</style>

<script define:vars={{ projects }}>
  document.addEventListener("DOMContentLoaded", () => {
    const tabs = document.querySelectorAll(".filter-tab");
    const cards = document.querySelectorAll(".liquid-glass-card");
    
    // Modal nodes
    const backdrop = document.getElementById("project-modal-backdrop");
    const box = document.getElementById("project-modal-box");
    const closeBtn = document.getElementById("project-modal-close");
    
    const mDate = document.getElementById("modal-project-date");
    const mBadge = document.getElementById("modal-project-badge");
    const mTitle = document.getElementById("modal-project-title");
    const mSubtitle = document.getElementById("modal-project-subtitle");
    const mDesc = document.getElementById("modal-project-desc");
    const mFeatures = document.getElementById("modal-project-features");
    const mSkills = document.getElementById("modal-project-skills");
    
    const mRole = document.getElementById("modal-meta-role");
    const mClient = document.getElementById("modal-meta-client");
    const mChallengeProb = document.getElementById("modal-challenge-prob");
    const mChallengeSol = document.getElementById("modal-challenge-sol");
    
    const mGithub = document.getElementById("modal-github-btn");
    const mLive = document.getElementById("modal-live-btn");
    const mArch = document.getElementById("modal-architecture-container");
    const mMetrics = document.getElementById("modal-project-metrics");

    const catLabels = {
      "ai-ml": "AI & Deep Learning",
      "cloud-devops": "Cloud & DevOps",
      "distributed-systems": "Distributed Systems",
      "fullstack": "Full-Stack Web"
    };

    // --- Dynamic Filtering Logic ---
    if (tabs.length > 0) {
      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const filter = tab.getAttribute("data-filter");

          // Clear active styles
          tabs.forEach((t) => {
            t.className = "filter-tab px-5 py-2.5 rounded-full text-xs sm:text-sm font-medium border border-white/60 bg-white/40 text-gray-700 hover:bg-white/75 hover:border-white/80 hover:text-black shadow-sm backdrop-blur-md transition-all duration-300 cursor-pointer font-san";
          });

          // Set active classes on clicked tab
          tab.className = "filter-tab px-5 py-2.5 rounded-full text-xs sm:text-sm font-medium border border-gray-900 bg-gray-900 text-white shadow-sm active-all transition-all duration-300 cursor-pointer font-san";

          // Filter cards
          cards.forEach((card) => {
            const category = card.getAttribute("data-category");
            
            if (filter === "all" || category === filter) {
              card.classList.remove("project-card-filtered-out");
              card.style.display = "flex";
            } else {
              card.classList.add("project-card-filtered-out");
              setTimeout(() => {
                if (card.classList.contains("project-card-filtered-out")) {
                  card.style.display = "none";
                }
              }, 300);
            }
          });
        });
      });
    }

    // --- Modal Open/Close handlers ---
    function openModal() {
      if (!backdrop || !box) return;
      backdrop.classList.remove("opacity-0", "pointer-events-none");
      backdrop.classList.add("opacity-100");
      box.classList.remove("scale-95", "opacity-0");
      box.classList.add("scale-100", "opacity-100");
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      if (!backdrop || !box) return;
      backdrop.classList.remove("opacity-100");
      backdrop.classList.add("opacity-0", "pointer-events-none");
      box.classList.remove("scale-100", "opacity-100");
      box.classList.add("scale-95", "opacity-0");
      document.body.style.overflow = "";
    }

    // Capture case study click
    const triggers = document.querySelectorAll(".project-details-trigger");
    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const id = trigger.getAttribute("data-project-id");
        const project = projects.find(p => p.id === id);
        if (!project) return;

        // Populate basic information
        if (mDate) mDate.textContent = project.date;
        if (mBadge) mBadge.textContent = catLabels[project.category] || "";
        if (mTitle) mTitle.textContent = project.title;
        if (mSubtitle) mSubtitle.textContent = project.subtitle;
        if (mDesc) mDesc.textContent = project.detailedDescription;

        // Populate micro metadata
        if (mRole) mRole.textContent = project.role;
        if (mClient) mClient.textContent = project.client;
        if (mChallengeProb) mChallengeProb.textContent = project.challenges.problem;
        if (mChallengeSol) mChallengeSol.textContent = project.challenges.solution;

        // Ingest features list
        if (mFeatures) {
          mFeatures.innerHTML = "";
          project.features.forEach(feature => {
            const li = document.createElement("li");
            li.className = "flex items-start gap-2.5";
            li.innerHTML = `
              <svg class="w-4 h-4 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span>${feature}</span>
            `;
            mFeatures.appendChild(li);
          });
        }

        // Ingest skills tags
        if (mSkills) {
          mSkills.innerHTML = "";
          project.skills.forEach(skill => {
            const span = document.createElement("span");
            span.className = "bg-white/50 text-gray-755 border border-white/70 text-[11px] px-2.5 py-0.5 rounded-full font-medium shadow-sm";
            span.textContent = skill;
            mSkills.appendChild(span);
          });
        }

        // Ingest links
        if (mGithub) mGithub.setAttribute("href", project.githubUrl);
        if (mLive) {
          if (project.liveUrl) {
            mLive.style.display = "inline-flex";
            mLive.setAttribute("href", project.liveUrl);
          } else {
            mLive.style.display = "none";
          }
        }

        // Generate Architecture diagrams nodes dynamically
        if (mArch) {
          mArch.innerHTML = "";
          const headerNode = document.createElement("div");
          headerNode.className = "w-full text-center py-1 bg-[#10B981]/10 text-[#10B981] border border-[#10B981]/20 rounded-xl text-[10px] font-semibold tracking-wide shadow-[inset_0_1px_2px_rgba(255,255,255,0.8)]";
          headerNode.innerHTML = `System Overview: <strong>${project.title}</strong>`;
          mArch.appendChild(headerNode);

          const listContainer = document.createElement("div");
          listContainer.className = "flex flex-col gap-2 w-full mt-2";
          project.architecture.nodes.forEach((nodeStr, nIdx) => {
            const divNode = document.createElement("div");
            divNode.className = "p-2 bg-white/85 border border-gray-150 rounded-xl text-[10px] text-gray-700 flex items-start gap-2.5 shadow-sm";
            divNode.innerHTML = `
              <span class="w-4 h-4 flex items-center justify-center bg-gray-900 text-white rounded-md text-[8px] font-semibold mt-0.5">${nIdx + 1}</span>
              <span class="leading-tight">${nodeStr}</span>
            `;
            listContainer.appendChild(divNode);
          });
          mArch.appendChild(listContainer);
        }

        // Generate metrics boxes
        if (mMetrics) {
          mMetrics.innerHTML = "";
          project.stats.forEach(m => {
            const metBox = document.createElement("div");
            metBox.className = "bg-white/60 border border-white/80 p-3 rounded-2xl text-center shadow-sm backdrop-blur-sm shadow-[inset_0_1px_2px_rgba(255,255,255,0.7)]";
            metBox.innerHTML = `
              <span class="block text-[9px] font-bold text-gray-400 uppercase tracking-wide truncate">${m.label}</span>
              <span class="block text-sm sm:text-base font-semibold text-gray-900 mt-1 font-san">${m.value}</span>
            `;
            mMetrics.appendChild(metBox);
          });
        }

        openModal();
      });
    });

    // Close button interactions
    if (closeBtn) closeBtn.addEventListener("click", closeModal);
    if (backdrop) {
      backdrop.addEventListener("click", (e) => {
        if (e.target === backdrop) closeModal();
      });
    }
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });
  });
</script>
