---
// src/pages/volunteer.astro
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Volunteer from "../components/Volunteer.astro";

const title = "Volunteer Experience | Yasith Tharuka";
const description = "A detailed showcase of my volunteer work, community contributions, and leadership initiatives across organizations.";
---

<Layout title={title}>
  <main class="w-full pt-28 bg-[#FAFAFC] relative min-h-screen">
    <!-- Bubble glow decoration inside the page wrapper -->
    <div class="absolute top-20 right-10 w-96 h-96 rounded-full bg-blue-300/5 blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-20 left-10 w-96 h-96 rounded-full bg-emerald-300/5 blur-3xl pointer-events-none"></div>

    <!-- Top return bar -->
    <div class="max-w-6xl mx-auto px-6 mb-2 relative z-20">
      <div class="flex items-center justify-between">
        <a
          href="/"
          class="inline-flex items-center gap-2 bg-white/20 hover:bg-white/35 text-gray-900 hover:text-black px-6 py-2.5 rounded-full text-xs sm:text-sm font-medium transition-all duration-200 hover:-translate-y-0.5 font-san border border-white/30 hover:border-white/50 shadow-sm backdrop-blur-md"
          id="back-home-button"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
             <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Return to Home
        </a>
      </div>
    </div>

    <!-- Render the Volunteer component (no limit, displays all 10) -->
    <Volunteer />
  </main>
  <Footer />
</Layout>
