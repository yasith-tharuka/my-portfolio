---

<div class="relative overflow-hidden w-full bg-[#FAFAFC] border-t border-gray-150 py-20 font-body">
  <!-- Interactive Background Glowing Refraction Bubbles -->
  <div class="absolute top-10 left-5 w-64 h-64 rounded-full bg-blue-400/15 blur-3xl animate-float-bubble-1 pointer-events-none"></div>
  <div class="absolute bottom-10 right-5 w-72 h-72 rounded-full bg-emerald-400/12 blur-3xl animate-float-bubble-2 pointer-events-none"></div>
  <div class="absolute top-1/3 left-1/4 w-48 h-48 rounded-full bg-purple-400/10 blur-3xl animate-float-bubble-3 pointer-events-none"></div>
  <div class="absolute bottom-1/3 right-1/4 w-52 h-52 rounded-full bg-amber-400/8 blur-3xl animate-float-bubble-1 pointer-events-none"></div>

  <!-- Content Container -->
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14">
      <div class="max-w-2xl">
        <span class="text-xs font-semibold text-[#4285F4] uppercase tracking-widest block mb-2 font-san">Academic dossier</span>
        <h2 class="font-san text-3xl sm:text-4xl md:text-5xl font-normal text-gray-900 leading-[1.15] tracking-tight">
          Education &<br class="hidden sm:inline" /> academic journey
        </h2>
        <p class="text-sm sm:text-base text-gray-500 leading-relaxed mt-3 font-light">
          A verified chronicle of my academic degrees, GPA standings, leadership roles, and transcripts.
        </p>
      </div>
    </div>

    <!-- Apple Liquid Glass Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {educationData.map((edu) => (
        <div 
          class="liquid-glass-card group relative p-6 sm:p-8 flex flex-col justify-between"
          id={`edu-card-${edu.id}`}
        >
          <!-- Accent bubble glow overlay that animates on card hover -->
          <div 
            class="absolute -top-10 -left-10 w-24 h-24 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-2xl pointer-events-none"
            style={`background-color: ${edu.accentColor}20`}
          ></div>

          <div>
            <!-- Header: Logo and Period Tag -->
            <div class="flex items-center justify-between gap-4 mb-5">
              <!-- Logo Container with Liquid glass style -->
              <span class="w-14 h-14 flex items-center justify-center bg-white/60 border border-white/70 backdrop-blur-md rounded-2xl shadow-[inset_0_1px_2px_rgba(255,255,255,0.8)] p-2.5 flex-shrink-0 transition-all duration-300 group-hover:scale-105 group-hover:bg-white/80">
                {edu.logoType === 'sliit' ? (
                  <img src={edu.logo} alt="SLIIT" class="w-full h-full object-contain" />
                ) : edu.logoType === 'othm' ? (
                  <div class="flex flex-col items-center justify-center leading-none">
                    <span class="font-san font-extrabold text-[13px] text-purple-600 tracking-tighter">OTHM</span>
                    <span class="text-[5px] font-semibold text-gray-400 tracking-widest mt-0.5">UK</span>
                  </div>
                ) : (
                  <div class="flex flex-col items-center justify-center text-amber-500">
                    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                    </svg>
                  </div>
                )}
              </span>

              <!-- Academic Period Capsule Tag -->
              <span class="px-3.5 py-1 text-[11px] font-semibold uppercase tracking-wider rounded-full bg-white/45 border border-white/60 shadow-sm text-gray-500 backdrop-blur-sm">
                {edu.period}
              </span>
            </div>

            <!-- Degree Title -->
            <h3 class="font-san text-lg sm:text-xl font-medium tracking-normal text-gray-900 leading-snug group-hover:text-[#4285F4] transition-colors">
              {edu.degree}
            </h3>

            <!-- Institution Name -->
            <p class="text-xs font-semibold text-gray-500 mt-1 font-sans">
              {edu.institution}
            </p>

            <!-- Grade Standing Capsule -->
            <div class="mt-3.5 flex items-center gap-2">
              <span class={`px-3 py-1 rounded-full text-xs font-semibold border ${edu.gradeColor} shadow-[0_1px_2px_rgba(0,0,0,0.02)] backdrop-blur-sm`}>
                {edu.grade}
              </span>
              {edu.gradeSub && (
                <span class="text-[11px] text-gray-400 font-light truncate max-w-[200px]" title={edu.gradeSub}>
                  {edu.gradeSub}
                </span>
              )}
            </div>

            <!-- Core Competencies / Skills (Pill badges) -->
            <div class="mt-5 flex flex-wrap gap-1.5">
              {edu.skills.map((skill) => (
                <span 
                  class="px-2.5 py-1 rounded-lg text-[10px] font-medium bg-white/60 border border-white/70 text-gray-650 shadow-[0_1px_2px_rgba(0,0,0,0.01)] select-none hover:border-gray-300 transition-colors"
                  style={`--hover-accent: ${edu.accentColor}`}
                >
                  {skill}
                </span>
              ))}
            </div>

            <!-- Activities list (Compact bullet list) -->
            <div class="mt-6 border-t border-gray-200/40 pt-4">
              <span class="text-[9px] font-bold text-gray-400 uppercase tracking-widest block mb-2.5">Key Activities & Roles</span>
              <ul class="space-y-2.5 text-xs text-gray-550 leading-relaxed font-light font-sans">
                {edu.activities.map((act) => (
                  <li class="flex items-start gap-2.5 group/item">
                    <span 
                      class="w-1.5 h-1.5 rounded-full flex-shrink-0 mt-1.5 transition-colors duration-300"
                      style={`background-color: ${edu.accentColor}`}
                    ></span>
                    <div>
                      <strong class="font-semibold text-gray-700 group-hover/item:text-black transition-colors">{act.role}</strong>
                      <span class="text-gray-400 mx-1">—</span>
                      <span class="text-gray-500">{act.desc}</span>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Verified Document attachments list -->
          <div class="mt-6 border-t border-gray-200/40 pt-4 flex flex-col gap-3">
            {edu.documents.length > 0 ? (
              <div>
                <span class="text-[9px] font-bold text-gray-400 uppercase tracking-widest block mb-2">Verified Credentials</span>
                <div class="flex flex-wrap gap-2.5">
                  {edu.documents.map((doc) => (
                    <button 
                      class="document-preview-card flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/50 border border-white/60 hover:bg-white/80 hover:border-white/80 text-[11px] font-semibold text-gray-650 hover:text-black transition-all duration-300 cursor-pointer group/doc shadow-sm hover:scale-[1.02]"
                      data-doc-name={doc.name}
                      data-doc-url={doc.url}
                      data-doc-type={doc.type}
                      data-doc-desc={doc.description}
                    >
                      <!-- Icon according to document type -->
                      {doc.type === 'pdf' ? (
                        <svg class="w-3.5 h-3.5 text-red-500 group-hover/doc:scale-105 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                        </svg>
                      ) : doc.type === 'image' ? (
                        <svg class="w-3.5 h-3.5 text-blue-500 group-hover/doc:scale-105 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                      ) : (
                        <svg class="w-3.5 h-3.5 text-amber-500 group-hover/doc:scale-105 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                      )}
                      <span>{doc.name}</span>
                    </button>
                  ))}
                </div>
              </div>
            ) : (
              <div class="flex items-center gap-2 text-[10px] text-gray-400 font-light font-sans bg-white/20 border border-white/20 p-2.5 rounded-xl">
                <span class="w-1.5 h-1.5 rounded-full bg-blue-500/60 animate-pulse"></span>
                <span>{edu.id === 'sliit-hdip' ? "Graduation artifacts expected modular release 2027" : "Academic registry verified entry"}</span>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Document Overlay Viewer Lightbox Modal -->
  <div id="edu-lightbox" class="fixed inset-0 z-50 bg-black/85 backdrop-blur-md hidden justify-center items-center p-4">
    <!-- Lightbox Container Card with Premium Glass Styles -->
    <div class="bg-white rounded-[2rem] w-full max-w-5xl h-[85vh] flex flex-col relative overflow-hidden shadow-2xl scale-95 opacity-0 transition-all duration-300" id="edu-lightbox-container">
      
      <!-- Header Panel -->
      <div class="px-6 py-4 border-b border-gray-150 flex items-center justify-between bg-white relative z-10">
        <div>
          <h3 class="font-san font-semibold text-gray-900 text-base" id="edu-lightbox-title">Document Viewer</h3>
          <p class="text-[11px] text-gray-500 font-light truncate max-w-md sm:max-w-xl" id="edu-lightbox-desc">Document verification details...</p>
        </div>

        <div class="flex items-center gap-2">
          <!-- Download Link Button -->
          <a 
            href="#" 
            download 
            id="edu-lightbox-download" 
            class="w-10 h-10 rounded-full bg-gray-50 border border-gray-150 text-gray-600 hover:text-black hover:bg-gray-100 flex items-center justify-center transition-colors cursor-pointer"
            title="Download File"
          >
            <svg class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
          </a>

          <!-- Close button -->
          <button 
            id="edu-lightbox-close" 
            class="w-10 h-10 rounded-full bg-gray-900 text-white hover:bg-gray-800 flex items-center justify-center transition-colors cursor-pointer"
            aria-label="Close viewer"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Render Content Area -->
      <div class="flex-1 w-full bg-gray-50 flex items-center justify-center overflow-auto p-4 relative" id="edu-lightbox-content">
        <!-- Dynamically filled with iframe or image tag -->
      </div>
    </div>
  </div>
</div>

<style>
  /* Floating bubbles keyframe animations */
  @keyframes float-bubble-1 {
    0% { transform: translateY(0px) translateX(0px) scale(1); }
    50% { transform: translateY(-40px) translateX(20px) scale(1.1); }
    100% { transform: translateY(0px) translateX(0px) scale(1); }
  }
  @keyframes float-bubble-2 {
    0% { transform: translateY(0px) translateX(0px) scale(1.05); }
    50% { transform: translateY(-30px) translateX(-25px) scale(0.95); }
    100% { transform: translateY(0px) translateX(0px) scale(1.05); }
  }
  @keyframes float-bubble-3 {
    0% { transform: translateY(0px) translateX(0px) rotate(0deg); }
    50% { transform: translateY(-20px) translateX(15px) rotate(180deg); }
    100% { transform: translateY(0px) translateX(0px) rotate(360deg); }
  }
  .animate-float-bubble-1 { animation: float-bubble-1 14s ease-in-out infinite; }
  .animate-float-bubble-2 { animation: float-bubble-2 16s ease-in-out infinite; }
  .animate-float-bubble-3 { animation: float-bubble-3 18s ease-in-out infinite; }

  /* Premium Apple Liquid Glass Card */
  .liquid-glass-card {
    position: relative;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.45) 0%, rgba(255, 255, 255, 0.1) 100%);
    backdrop-filter: blur(24px) saturate(190%);
    -webkit-backdrop-filter: blur(24px) saturate(190%);
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 
      inset 0 1.5px 0 rgba(255, 255, 255, 0.75), 
      inset 0 -1.5px 0 rgba(0, 0, 0, 0.05),
      0 10px 30px -10px rgba(0, 0, 0, 0.05),
      0 1px 3px rgba(0, 0, 0, 0.02);
    border-radius: 2.2rem;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
  }

  .liquid-glass-card:hover {
    transform: translateY(-6px) scale(1.01);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0.15) 100%);
    border-color: rgba(255, 255, 255, 0.65);
    box-shadow: 
      inset 0 2px 0 rgba(255, 255, 255, 0.85), 
      inset 0 -1px 0 rgba(0, 0, 0, 0.05),
      0 22px 40px -15px rgba(0, 0, 0, 0.12),
      0 2px 8px rgba(0, 0, 0, 0.04);
  }

  /* Liquid reflection gloss curvature across the top */
  .liquid-glass-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 45%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.35) 0%, rgba(255, 255, 255, 0) 100%);
    border-radius: 2.2rem 2.2rem 50% 50% / 2.2rem 2.2rem 20% 20%;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .liquid-glass-card:hover::before {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.45) 0%, rgba(255, 255, 255, 0) 100%);
  }

  /* Core Competencies skill tag hover accent glow effect */
  span[style*="--hover-accent"] {
    transition: all 0.2s ease;
  }
  span[style*="--hover-accent"]:hover {
    border-color: var(--hover-accent);
    color: #111111;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px var(--hover-accent)12;
  }
</style>

<script>
  // Lightbox Media Viewer Modal Dialog logic
  const docPreviewCards = document.querySelectorAll(".document-preview-card");
  const lightboxModal = document.getElementById("edu-lightbox");
  const lightboxContainer = document.getElementById("edu-lightbox-container");
  const closeBtn = document.getElementById("edu-lightbox-close");
  const docTitle = document.getElementById("edu-lightbox-title");
  const docDesc = document.getElementById("edu-lightbox-desc");
  const downloadBtn = document.getElementById("edu-lightbox-download") as HTMLAnchorElement | null;
  const contentWrapper = document.getElementById("edu-lightbox-content");

  function openLightbox(name: string, url: string, type: string, description: string) {
    if (!lightboxModal || !lightboxContainer || !docTitle || !docDesc || !contentWrapper) return;

    docTitle.textContent = name;
    docDesc.textContent = description;
    if (downloadBtn) {
      downloadBtn.href = url;
    }

    // Clear content wrapper
    contentWrapper.innerHTML = "";

    // Show according to type
    if (type === 'pdf') {
      const iframe = document.createElement("iframe");
      iframe.src = url;
      iframe.className = "w-full h-full border-0 rounded-2xl bg-white shadow-inner";
      contentWrapper.appendChild(iframe);
    } else if (type === 'image') {
      const img = document.createElement("img");
      img.src = url;
      img.alt = name;
      img.className = "max-w-full max-h-full object-contain rounded-2xl shadow-md";
      contentWrapper.appendChild(img);
    } else if (type === 'link') {
      const linkCard = document.createElement("div");
      linkCard.className = "bg-white p-8 rounded-3xl border border-gray-150 max-w-md text-center flex flex-col items-center shadow-lg my-auto";
      linkCard.innerHTML = `
        <div class="w-16 h-16 bg-amber-500/10 text-amber-500 rounded-full flex items-center justify-center mb-4 border border-amber-100 animate-pulse">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </div>
        <h3 class="font-san font-semibold text-gray-900 text-lg mb-2">Verified Result Portal</h3>
        <p class="text-xs text-gray-500 font-light leading-relaxed mb-6">
          This secondary credential is authenticated through the Ministry of Education results portal. Click below to verify manually.
        </p>
        <a href="${url}" target="_blank" class="px-6 py-2.5 bg-gray-900 hover:bg-gray-800 text-white rounded-full text-xs font-semibold transition-all inline-flex items-center gap-2">
          Open External Portal
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      `;
      contentWrapper.appendChild(linkCard);
    }

    // Toggle Modal visibility
    lightboxModal.classList.remove("hidden");
    lightboxModal.classList.add("flex");
    document.body.style.overflow = "hidden"; // Disable background scrolling

    // Trigger transitions
    setTimeout(() => {
      lightboxContainer.classList.remove("scale-95", "opacity-0");
    }, 10);
  }

  function closeLightbox() {
    if (!lightboxModal || !lightboxContainer || !contentWrapper) return;

    lightboxContainer.classList.add("scale-95", "opacity-0");
    
    setTimeout(() => {
      lightboxModal.classList.remove("flex");
      lightboxModal.classList.add("hidden");
      document.body.style.overflow = ""; // Restore scrolling
      contentWrapper.innerHTML = ""; // Clear iframe to stop pdf/media playback
    }, 250);
  }

  // Bind preview clicks
  docPreviewCards.forEach((card) => {
    card.addEventListener("click", () => {
      const name = card.getAttribute("data-doc-name") || "Document";
      const url = card.getAttribute("data-doc-url") || "";
      const type = card.getAttribute("data-doc-type") || "image";
      const description = card.getAttribute("data-doc-desc") || "";
      openLightbox(name, url, type, description);
    });
  });

  // Bind close button click
  if (closeBtn) closeBtn.addEventListener("click", closeLightbox);

  // Bind modal background click
  if (lightboxModal) {
    lightboxModal.addEventListener("click", (e) => {
      if (e.target === lightboxModal) closeLightbox();
    });
  }

  // Bind ESC key to close modal
  window.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && lightboxModal && !lightboxModal.classList.contains("hidden")) {
      closeLightbox();
    }
  });
</script>
